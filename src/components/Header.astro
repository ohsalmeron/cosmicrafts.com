---
---

<header class="w-full max-w-7xl mx-auto flex justify-between items-center z-20 pb-4 border-b border-white/5 relative">
  <!-- Left: Cosmicrafts Logo -->
  <a href="/" class="flex flex-col gap-0.5 select-none group">
    <img src="/logo.svg" alt="Cosmicrafts Logo" class="h-8 md:h-10 opacity-90 group-hover:scale-[1.01] transition-transform duration-300" />
    <span class="text-[8px] md:text-[9px] text-slate-500 font-mono tracking-widest uppercase">[ STAGING_INFRA ]</span>
  </a>

  <!-- Right: Web3 Wallet & Token Readout -->
  <div class="flex items-center space-x-4">
    <!-- Logged In Content -->
    <div id="logged-in-container" class="hidden items-center space-x-4">
      <!-- Spiral Token Balance -->
      <div class="flex items-center space-x-2 bg-cyan-950/20 border border-cyan-500/10 px-3 py-1.5 rounded-lg backdrop-blur-md">
        <img src="/assets/icons/spiral.svg" alt="Spiral Icon" class="w-4 h-4 md:w-5 md:h-5 animate-spin-slow drop-shadow-[0_0_5px_rgba(34,211,238,0.5)]" />
        <div class="flex flex-col text-left font-mono">
          <span class="text-[10px] md:text-xs font-bold text-white leading-none">12,500</span>
          <span class="text-[7px] md:text-[8px] text-cyan-400 tracking-wider leading-none">SPIRAL</span>
        </div>
      </div>

      <!-- User Wallet Avatar & Info -->
      <div class="relative flex items-center space-x-2 bg-slate-900/40 border border-white/5 pl-3 pr-2 py-1 rounded-lg backdrop-blur-md cursor-pointer group" id="user-menu-trigger">
        <div class="flex flex-col text-right font-mono hidden sm:flex">
          <span class="text-[9px] md:text-[10px] font-bold text-white leading-none">BIZKIT_0x1337</span>
          <span class="text-[7px] text-emerald-400 tracking-wider leading-none flex items-center justify-end gap-1 mt-0.5">
            <span class="inline-block w-1 h-1 rounded-full bg-emerald-400 animate-pulse"></span>
            ETHEREUM
          </span>
        </div>
        <!-- User Avatar Circle -->
        <div class="relative w-8 h-8 rounded-full border border-cyan-500/30 overflow-hidden group-hover:border-cyan-400 transition-colors duration-300">
          <img src="/assets/avatar.webp" alt="User Avatar" class="w-full h-full object-cover" />
        </div>

        <!-- Sci-fi Dropdown Menu -->
        <div class="absolute top-12 right-0 w-56 backdrop-blur-xl bg-slate-950/95 border border-cyan-500/20 rounded-xl p-4 shadow-[0_10px_40px_rgba(6,182,212,0.15)] hidden flex-col gap-3 font-mono text-[10px] text-slate-400 z-50 text-left" id="user-dropdown">
          <!-- Corner brackets for dropdown -->
          <div class="absolute top-0 left-0 w-3 h-3 border-t border-l border-cyan-400/40"></div>
          <div class="absolute top-0 right-0 w-3 h-3 border-t border-r border-cyan-400/40"></div>
          <div class="absolute bottom-0 left-0 w-3 h-3 border-b border-l border-cyan-400/40"></div>
          <div class="absolute bottom-0 right-0 w-3 h-3 border-b border-r border-cyan-400/40"></div>

          <div class="border-b border-white/5 pb-2">
            <span class="text-cyan-400 block text-[9px] tracking-wider mb-0.5">[ NETWORK STATUS ]</span>
            <span class="text-white font-bold">ETH_MAINNET (CONNECTED)</span>
          </div>

          <div class="flex flex-col gap-1">
            <span class="text-slate-500 text-[8px]">[ ADDRESS ]</span>
            <span class="text-white text-xs select-text">0x71C...9312</span>
          </div>

          <button id="btn-logout" class="w-full py-2 bg-rose-500/10 border border-rose-500/20 hover:bg-rose-500/20 text-rose-400 font-mono text-[9px] tracking-widest uppercase rounded transition-all duration-300 mt-1">
            Disconnect
          </button>
        </div>
      </div>
    </div>

    <!-- Logged Out Content -->
    <div id="logged-out-container" class="flex items-center">
      <button id="btn-open-login" class="px-4 py-2 bg-gradient-to-r from-cyan-500 to-indigo-500 hover:from-cyan-400 hover:to-indigo-400 text-white font-mono text-[10px] md:text-xs tracking-widest uppercase rounded-lg shadow-[0_0_20px_rgba(6,182,212,0.2)] transition-all duration-300 transform active:scale-95">
        Connect Wallet
      </button>
    </div>
  </div>

  <!-- Interactive Multi-Wallet Login Modal -->
  <div id="login-modal" class="fixed inset-0 z-[9999] hidden items-center justify-center p-4 bg-slate-950/40 backdrop-blur-md">
    <!-- Backdrop dismiss -->
    <div class="absolute inset-0 z-0" id="login-modal-backdrop"></div>
    
    <div class="relative w-full max-w-md backdrop-blur-xl bg-slate-950/85 border border-cyan-500/20 rounded-2xl p-6 md:p-8 shadow-[0_0_50px_rgba(6,182,212,0.15)] flex flex-col z-10 text-center select-none overflow-hidden">
      <!-- Cyber Corner Brackets -->
      <div class="absolute top-0 left-0 w-5 h-5 border-t border-l border-cyan-400/40"></div>
      <div class="absolute top-0 right-0 w-5 h-5 border-t border-r border-cyan-400/40"></div>
      <div class="absolute bottom-0 left-0 w-5 h-5 border-b border-l border-cyan-400/40"></div>
      <div class="absolute bottom-0 right-0 w-5 h-5 border-b border-r border-cyan-400/40"></div>

      <!-- Header -->
      <div class="flex items-center justify-between text-[8px] md:text-[9px] text-cyan-500 font-mono tracking-widest uppercase mb-4 border-b border-white/5 pb-2">
        <span>[ SECURITY_LOG: CONNECT ]</span>
        <button id="btn-close-login" class="hover:text-white transition-colors">CLOSE ✕</button>
      </div>

      <h1 class="text-xl md:text-2xl font-black text-white uppercase tracking-tight mb-2">Connect Wallet</h1>
      <p class="text-[11px] text-slate-400 font-light mb-6">Select a cryptographic provider to establish your Cosmic Profile.</p>

      <!-- Primary Methods -->
      <div class="space-y-2 mb-4">
        <!-- MetaMask (EVM) -->
        <button class="w-full py-2.5 px-4 bg-white/5 border border-white/5 hover:border-cyan-500/30 hover:bg-cyan-950/15 text-white font-mono text-[10px] md:text-xs tracking-wider uppercase rounded-xl flex items-center justify-between transition-all duration-300 wallet-option" data-wallet="metamask">
          <span class="flex items-center gap-3">
            <img src="/assets/icons/metamask.svg" alt="MetaMask" class="w-5 h-5" />
            <span>METAMASK (EVM)</span>
          </span>
          <span class="text-[8px] text-emerald-400 uppercase">[ ACTIVE ]</span>
        </button>

        <!-- Phantom (Solana) -->
        <button class="w-full py-2.5 px-4 bg-white/5 border border-white/5 hover:border-cyan-500/30 hover:bg-cyan-950/15 text-white font-mono text-[10px] md:text-xs tracking-wider uppercase rounded-xl flex items-center justify-between transition-all duration-300 wallet-option" data-wallet="phantom">
          <span class="flex items-center gap-3">
            <img src="/assets/icons/phantom.svg" alt="Phantom" class="w-5 h-5" />
            <span>PHANTOM (SOLANA)</span>
          </span>
          <span class="text-[8px] text-slate-500 uppercase">[ INSTALLED ]</span>
        </button>

        <!-- XVerse (Bitcoin) -->
        <button class="w-full py-2.5 px-4 bg-white/5 border border-white/5 hover:border-cyan-500/30 hover:bg-cyan-950/15 text-white font-mono text-[10px] md:text-xs tracking-wider uppercase rounded-xl flex items-center justify-between transition-all duration-300 wallet-option" data-wallet="xverse">
          <span class="flex items-center gap-3">
            <img src="/assets/icons/xverse.svg" alt="XVerse" class="w-5 h-5" />
            <span>XVERSE (BITCOIN)</span>
          </span>
          <span class="text-[8px] text-slate-500 uppercase">[ INSTALLED ]</span>
        </button>

        <!-- Internet Identity (ICP) -->
        <button class="w-full py-2.5 px-4 bg-white/5 border border-white/5 hover:border-cyan-500/30 hover:bg-cyan-950/15 text-white font-mono text-[10px] md:text-xs tracking-wider uppercase rounded-xl flex items-center justify-between transition-all duration-300 wallet-option" data-wallet="icp">
          <span class="flex items-center gap-3">
            <img src="/assets/icons/icp.svg" alt="Internet Identity" class="w-5 h-5" />
            <span>INTERNET IDENTITY</span>
          </span>
          <span class="text-[8px] text-slate-500 uppercase">[ COMPATIBLE ]</span>
        </button>
      </div>

      <!-- Other Wallets -->
      <div class="grid grid-cols-2 gap-2 text-[9px] font-mono border-t border-white/5 pt-4 mt-2">
        <button class="py-2 border border-white/5 bg-white/5 hover:border-cyan-500/30 rounded text-slate-400 hover:text-white flex items-center justify-center gap-2 wallet-option" data-wallet="okx">
          <img src="/assets/icons/okx.svg" alt="OKX" class="w-3.5 h-3.5" />
          <span>OKX WALLET</span>
        </button>
        <button class="py-2 border border-white/5 bg-white/5 hover:border-cyan-500/30 rounded text-slate-400 hover:text-white flex items-center justify-center gap-2 wallet-option" data-wallet="plug">
          <img src="/assets/icons/plug.svg" alt="Plug" class="w-3.5 h-3.5" />
          <span>PLUG WALLET</span>
        </button>
      </div>
    </div>
  </div>

  <!-- Simulated Signing Overlay -->
  <div id="signing-overlay" class="fixed inset-0 z-[10000] hidden items-center justify-center bg-slate-950/60 backdrop-blur-md font-mono select-none">
    <div class="text-center space-y-4 max-w-sm px-6">
      <div class="w-10 h-10 border border-t-2 border-cyan-400 border-t-transparent rounded-full animate-spin mx-auto"></div>
      <h2 class="text-sm font-bold text-white uppercase tracking-widest">SIGNING TRANSMISSION</h2>
      <p class="text-[10px] text-slate-400 leading-normal">Please approve the signature request in your wallet to deterministically derive your cross-chain profile identities...</p>
    </div>
  </div>
</header>

<script>
  // UI selectors
  const loggedInContainer = document.getElementById('logged-in-container');
  const loggedOutContainer = document.getElementById('logged-out-container');
  const btnOpenLogin = document.getElementById('btn-open-login');
  const btnCloseLogin = document.getElementById('btn-close-login');
  const loginModal = document.getElementById('login-modal');
  const loginModalBackdrop = document.getElementById('login-modal-backdrop');
  const walletOptions = document.querySelectorAll('.wallet-option');
  const signingOverlay = document.getElementById('signing-overlay');
  const btnLogout = document.getElementById('btn-logout');

  // Check login state
  const checkLogin = () => {
    const isLoggedIn = sessionStorage.getItem('is_logged_in') === 'true';
    if (isLoggedIn) {
      loggedInContainer?.classList.remove('hidden');
      loggedInContainer?.classList.add('flex');
      loggedOutContainer?.classList.add('hidden');
    } else {
      loggedInContainer?.classList.add('hidden');
      loggedInContainer?.classList.remove('flex');
      loggedOutContainer?.classList.remove('hidden');
    }
  };

  // Open modal
  btnOpenLogin?.addEventListener('click', () => {
    loginModal?.classList.remove('hidden');
    loginModal?.classList.add('flex');
  });

  // Close modal
  const closeModal = () => {
    loginModal?.classList.add('hidden');
    loginModal?.classList.remove('flex');
  };
  btnCloseLogin?.addEventListener('click', closeModal);
  loginModalBackdrop?.addEventListener('click', closeModal);

  // Connect Simulation
  walletOptions.forEach(opt => {
    opt.addEventListener('click', () => {
      closeModal();
      signingOverlay?.classList.remove('hidden');
      signingOverlay?.classList.add('flex');
      
      setTimeout(() => {
        signingOverlay?.classList.add('hidden');
        signingOverlay?.classList.remove('flex');
        sessionStorage.setItem('is_logged_in', 'true');
        checkLogin();
        // Redirect to profile
        window.location.href = '/profile';
      }, 1800);
    });
  });

  // Logout Simulation
  btnLogout?.addEventListener('click', () => {
    sessionStorage.removeItem('is_logged_in');
    checkLogin();
    window.location.href = '/';
  });

  // Init State on Load
  checkLogin();
</script>

<style>
  @keyframes spin-slow {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
  .animate-spin-slow {
    animation: spin-slow 15s linear infinite;
  }
</style>
