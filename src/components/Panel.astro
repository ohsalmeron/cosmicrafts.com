---
// ponytail: single unified component for gorgeous sci-fi panels, preventing HTML duplicate bloat
interface Props {
  status?: string;
  title?: string;
  variant?: 'cyan' | 'purple' | 'emerald' | 'rose';
  class?: string;
  id?: string;
}

const { 
  status, 
  title, 
  variant = 'cyan', 
  class: className = '', 
  id 
} = Astro.props;

const styles = {
  cyan: {
    border: 'border-cyan-500/10 shadow-[0_0_50px_rgba(6,182,212,0.05)]',
    bracket: 'border-cyan-400/40',
    text: 'text-cyan-500'
  },
  purple: {
    border: 'border-purple-500/15 shadow-[0_0_50px_rgba(168,85,247,0.06)]',
    bracket: 'border-purple-400/40',
    text: 'text-purple-500'
  },
  emerald: {
    border: 'border-emerald-500/15 shadow-[0_0_50px_rgba(16,185,129,0.06)]',
    bracket: 'border-emerald-400/40',
    text: 'text-emerald-500'
  },
  rose: {
    border: 'border-rose-500/15 shadow-[0_0_50px_rgba(244,63,94,0.06)]',
    bracket: 'border-rose-400/40',
    text: 'text-rose-500'
  }
}[variant];
---

<div id={id} class={`relative backdrop-blur-lg bg-slate-950/40 border rounded-xl overflow-hidden ${styles.border} ${className}`}>
  <!-- Cyber Corner Brackets -->
  <div class={`absolute top-0 left-0 w-4 h-4 border-t border-l ${styles.bracket}`}></div>
  <div class={`absolute top-0 right-0 w-4 h-4 border-t border-r ${styles.bracket}`}></div>
  <div class={`absolute bottom-0 left-0 w-4 h-4 border-b border-l ${styles.bracket}`}></div>
  <div class={`absolute bottom-0 right-0 w-4 h-4 border-b border-r ${styles.bracket}`}></div>

  {status && (
    <div class="flex items-center justify-between text-[9px] font-mono tracking-widest uppercase mb-4 border-b border-white/5 pb-2 select-none">
      <span class={styles.text}>[ STATUS: {status} ]</span>
      {title && <span class="text-slate-500">{title}</span>}
    </div>
  )}

  <slot />
</div>
