type Cosmicrafts = 
 service {
   acceptFriendRequest: (fromId: PlayerId) -> (bool, text);
   add: (a: nat, b: nat) -> (nat);
   addAvatarToUser: (newAvatarId: nat) -> (bool, text);
   addProgressToIndividualAchievement: (user: PlayerId,
    individualAchievementId: nat, progressToAdd: nat) -> (bool);
   addTitleToUser: (newTitleId: nat) -> (bool, text);
   admin: (funcToCall: AdminFunction) -> (bool, text);
   adminUpdateMatch: (tournamentId: nat, matchId: nat, winnerIndex: nat,
    score: text) -> (bool);
   assignAchievementsToUser: (user: PlayerId) -> ();
   blockUser: (blockedId: PlayerId) -> (bool, text);
   burn: (args: BurnArgs) -> (TransferResult);
   cancelMatchmaking: () -> (bool, text);
   claimAchievementLineReward: (achievementId: nat) -> (bool, text);
   claimCategoryAchievementReward: (categoryId: nat) -> (bool, text);
   claimGeneralReward: (idMission: nat) -> (bool, text);
   claimIndividualAchievementReward: (achievementId: nat) -> (bool, text);
   claimUserReward: (idMission: nat) -> (bool, text);
   createAchievement: (categoryId: nat, name: text, rewards:
    vec AchievementReward) -> (bool, text, nat);
   createAchievementCategory: (name: text, rewards: vec AchievementReward) ->
    (bool, text, nat);
   createBatchOfUnassignedCodes: () -> (vec ReferralCode);
   createIndividualAchievement: (achievementId: nat, name: text,
    achievementType: AchievementType, requiredProgress: nat, rewards:
    vec AchievementReward) -> (bool, text, nat);
   createTournament: (name: text, startDate: Time, prizePool: text,
    expirationDate: Time) -> (nat);
   createUserMission: (user: PlayerId) -> (bool, text, nat);
   declineFriendRequest: (fromId: PlayerId) -> (bool, text);
   deleteAccount: () -> (bool, text);
   deleteAllTournaments: () -> (bool);
   deposit_cycles: () -> ();
   disputeMatch: (tournamentId: nat, matchId: nat, reason: text) -> (bool);
   dumpAllPlayerMultipliers: () -> (vec record {
                                          PlayerId;
                                          float64;
                                        }) query;
   getAchievements: () -> (vec AchievementCategory);
   getActiveTournaments: () -> (vec Tournament) query;
   getAllAchievementsData: () -> (vec AchievementCategory) query;
   getAllPlayers: () -> (vec Player) query;
   getAllSearching: () -> (vec MatchData) query;
   getAllTournaments: () -> (vec Tournament) query;
   getAvailableAvatarDetails: () -> (vec Avatar) query;
   getAvailableAvatars: () -> (vec nat) query;
   getAvailableTitleDetails: () -> (vec Title__1) query;
   getAvailableTitles: () -> (vec nat) query;
   getAvatarById: (id: nat) -> (Avatar);
   getAvatars: ("principal": principal) ->
    (vec record {
           TokenId;
           TokenMetadata;
         }) query;
   getBeyondReferrals: (playerId: PlayerId) -> (vec PlayerId) query;
   getBlockedUsers: () -> (vec PlayerId) query;
   getCanistergeekInformation: (request: GetInformationRequest) ->
    (GetInformationResponse) query;
   getCharacters: ("principal": principal) ->
    (vec record {
           TokenId;
           TokenMetadata;
         }) query;
   getChests: ("principal": principal) ->
    (vec record {
           TokenId;
           TokenMetadata;
         }) query;
   getCosmicraftsStats: () -> (OverallStats) query;
   getDirectReferrals: (playerId: PlayerId) -> (vec PlayerId) query;
   getFriendRequests: () -> (vec FriendRequest) query;
   getFriendsList: () -> (opt vec PlayerId) query;
   getFullProfile: (player: PlayerId) ->
    (opt record {
           Player;
           PlayerGamesStats;
           AverageStats;
         }) query;
   getGeneralMissionProgress: (user: principal, missionID: nat) ->
    (opt MissionsUser) query;
   getGeneralMissions: () -> (vec MissionsUser);
   getGrandReferrer: (playerId: PlayerId) -> (opt PlayerId) query;
   getInactiveTournaments: () -> (vec Tournament) query;
   getIndirectReferrals: (playerId: PlayerId) -> (vec PlayerId) query;
   getInitArgs: () -> (TokenInitArgs) query;
   getLastLogin: (playerId: PlayerId) ->
    (opt record {
           country: opt text;
           timestamp: nat64;
         }) query;
   getMatchDetails: (matchID: MatchID) ->
    (opt record {
           MatchData;
           vec record {
                 Player;
                 PlayerGamesStats;
               };
         }) query;
   getMatchHistoryByPrincipal: (player: PlayerId) ->
    (vec record {
           MatchID;
           opt BasicStats;
         }) query;
   getMatchIDsByPrincipal: (player: PlayerId) -> (vec MatchID) query;
   getMatchParticipants: (matchID: MatchID) ->
