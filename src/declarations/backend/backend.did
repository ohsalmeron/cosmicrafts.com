   characterID: nat;
   gamesPlayed: nat;
 };
type NumericEntity = 
 record {
   avg: nat64;
   first: nat64;
   last: nat64;
   max: nat64;
   min: nat64;
 };
type Notification = 
 record {
   from: PlayerId;
