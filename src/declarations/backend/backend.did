 };
type MissionType = 
 variant {
   DamageDealt;
   DamageTaken;
   EnergyUsed;
   FactionPlayed;
   GameModePlayed;
   GamesCompleted;
   GamesWon;
   Kills;
   UnitsDeployed;
   XPEarned;
 };
type MissionRewardType = 
 variant {
   Chest;
   Stardust;
 };
type MissionCategory = 
 variant {
   Achievement;
   Daily;
   Free;
   Hourly;
   Weekly;
 };
type MintReceipt = 
 variant {
   Err: MintError;
   Ok: TokenId;
 };
type MintError = 
 variant {
   AlreadyExistTokenId;
   GenericError: record {
                   error_code: nat;
                   message: text;
                 };
   InvalidRecipient;
   SupplyCapOverflow;
   Unauthorized;
 };
type MintArgs = 
 record {
   metadata: Metadata;
   to: Account;
   token_id: TokenId;
 };
type Mint = 
 record {
   amount: Balance;
   created_at_time: opt nat64;
   memo: opt blob;
   to: Account__1;
 };
type MetricsResponse = record {metrics: opt CanisterMetrics;};
type MetricsRequest = record {parameters: GetMetricsParameters;};
type MetricsGranularity = 
 variant {
   daily;
   hourly;
 };
type MetadataResult = 
 variant {
   Err: CallError;
   Ok: Metadata;
 };
type Metadata = 
 record {
   basic: opt BasicMetadata;
   category: Category;
   general: GeneralMetadata;
   skills: opt SkillMetadata;
   skins: opt SkinMetadata;
   soul: opt SoulMetadata;
 };
type MetaDatum = 
 record {
   text;
   Value;
 };
type MatchID = nat;
type MatchData = 
 record {
   matchID: MatchID;
   player1: MMInfo;
   player2: opt MMInfo;
   status: MMStatus;
 };
type Match = 
 record {
   id: nat;
   nextMatchId: opt nat;
   participants: vec principal;
   result: opt record {
                 score: text;
                 winner: principal;
               };
   status: text;
   tournamentId: nat;
 };
type MMStatus = 
 variant {
   Accepted;
   Accepting;
   Ended;
   InGame;
   Reserved;
   Searching;
 };
type MMSearchStatus = 
 variant {
   Assigned;
   Available;
   NotAvailable;
 };
type MMInfo = 
 record {
   elo: float64;
