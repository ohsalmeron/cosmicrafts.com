   icrc7_image: () -> (opt blob) query;
   icrc7_metadata: (tokenId: TokenId) -> (MetadataResult) query;
   icrc7_name: () -> (text) query;
   icrc7_owner_of: (tokenId: TokenId) -> (OwnerResult) query;
