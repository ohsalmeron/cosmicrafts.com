   icrc7_supply_cap: () -> (opt nat) query;
   icrc7_supported_standards: () -> (vec SupportedStandard) query;
   icrc7_symbol: () -> (text) query;
   icrc7_tokens_of: (account: Account) -> (TokensOfResult) query;
   icrc7_total_supply: () -> (nat) query;
   icrc7_transfer: (transferArgs: TransferArgs) -> (TransferReceipt);
   isEven: (n: nat) -> (bool) query;
   isGameMatched: () -> (bool, text) query;
   joinTournament: (tournamentId: nat) -> (bool);
   loadAchievements: () -> (bool);
