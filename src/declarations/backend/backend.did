   lastPlayerActive: nat64;
   matchAccepted: bool;
   playerGameData: PlayerGameData;
   username: Username;
 };
type LogMessagesData = 
 record {
   message: text;
   timeNanos: Nanos;
 };
type LogEntry = 
 record {
   amount: opt nat;
   itemType: ItemType;
   timestamp: nat64;
   tokenID: opt TokenID;
   user: principal;
 };
type Level = nat;
type ItemType = 
 variant {
   Chest;
   GameNFTs;
   Stardust;
 };
type IndividualAchievement = 
 record {
   achievementId: nat;
