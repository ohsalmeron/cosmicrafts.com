   getPlayerElo: (player: principal) -> (float64) query;
   getPlayerStats: (player: PlayerId) -> (opt PlayerGamesStats) query;
   getProfile: (player: PlayerId) -> (opt Player) query;
   getReferralCode: (player: PlayerId) -> (opt ReferralCode) query;
   getReferrer: (playerId: PlayerId) -> (opt PlayerId) query;
   getRegisteredUsers: (tournamentId: nat) -> (vec principal) query;
   getSelectedAvatar: () -> (opt nat) query;
   getSelectedTitle: () -> (opt nat) query;
