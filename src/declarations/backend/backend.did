   getMyStats: () -> (opt PlayerGamesStats) query;
   getNFTs: ("principal": principal) ->
    (vec record {
           TokenId;
           TokenMetadata;
         }) query;
   getNotifications: () -> (vec Notification) query;
   getPlayer: () -> (opt Player) query;
   getPlayerAverageStats: (_player: principal) -> (opt AverageStats) query;
