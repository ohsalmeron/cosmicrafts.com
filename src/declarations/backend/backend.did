   mintChest: (PlayerId: principal, rarity: nat) -> (bool, text);
   mintDeck: () -> (bool, text, vec TokenId);
   mintNFT: (mintArgs: MintArgs) -> (MintReceipt);
   openChest: (chestID: nat) -> (bool, text);
   saveFinishedGame: (matchID: MatchID, _playerStats:
    record {
      botDifficulty: nat;
      botMode: nat;
      characterID: nat;
      damageCritic: nat;
      damageDealt: nat;
      damageEvaded: nat;
      damageTaken: nat;
      deploys: nat;
      energyChargeRate: nat;
      energyGenerated: nat;
      energyUsed: nat;
      energyWasted: nat;
      faction: nat;
      gameMode: nat;
      kills: nat;
      secRemaining: nat;
      wonGame: bool;
      xpEarned: nat;
    }) -> (bool, text);
   searchActiveGeneralMissions: (user: principal) -> (vec MissionsUser) query;
   searchActiveUserMissions: (user: PlayerId) -> (vec MissionsUser) query;
   searchUserByUsername: (username: Username) -> (vec Player) query;
   selectRandomUnits: (deck: vec TokenId) -> (vec TokenId);
   sendFriendRequest: (friendId: PlayerId) -> (bool, text);
   setMessage: (newMessage: text) -> ();
   setPlayerActive: () -> (bool);
   setPrivacySetting: (setting: PrivacySetting) -> (bool, text);
   signup: (username: Username, avatar: AvatarID, referralCode:
    opt ReferralCode, language: text) -> (bool, opt Player, text);
   storeCurrentDeck: (newDeck: vec TokenId) -> (bool);
   submitFeedback: (_tournamentId: nat, feedbackText: text) -> (bool);
   submitMatchResult: (tournamentId: nat, matchId: nat, score: text) ->
    (bool);
   test: (playerId: PlayerId) ->
    (opt
      record {
        elo: float64;
        gamesLost: nat;
        gamesWon: nat;
        level: Level;
        username: Username;
        xp: nat;
      }) query;
   topPlayersByMultiplier: (page: nat) ->
    (vec record {
           PlayerId;
           float64;
         }) query;
   unblockUser: (blockedId: PlayerId) -> (bool, text);
   updateAddFriendAchievement: (user: PlayerId) -> (bool, text);
   updateAvatar: (avatarId: nat) -> (bool, text);
   updateAvatarChangeAchievement: (user: PlayerId) -> (bool, text);
   updateBracket: (tournamentId: nat) -> (bool);
   updateBracketAfterMatchUpdate: (tournamentId: nat, matchId: nat, winner:
    principal) -> ();
   updateCanistergeekInformation: (request: UpdateInformationRequest) -> ();
   updateDescription: (description: Description) -> (bool, PlayerId, text);
   updatePlayerGameStats: (playerId: PlayerId, _playerStats: PlayerStats,
    _winner: nat, _looser: nat) -> () oneway;
   updatePlayerLevel: (playerId: principal) -> ();
   updateProgressManager: (user: principal, playerStats: PlayerStats) ->
    (bool, text);
   updateSoulNFTPlayed: (playerDeck: vec TokenId) -> (vec TokenId);
   updateTitle: (titleId: nat) -> (bool, text);
   updateUpgradeNFTAchievement: (user: PlayerId) -> (bool, text);
   updateUsername: (username: Username) -> (bool, PlayerId, text);
   upgradeNFT: (nftID: TokenID) -> (bool, text);
 };
type CollectionMetadata = 
 record {
   description: opt text;
   image: opt blob;
   name: text;
   royalties: opt nat16;
   royaltyRecipient: opt Account;
   supplyCap: opt nat;
   symbol: text;
   totalSupply: nat;
 };
type CollectionInitArgs = 
 record {
   description: opt text;
   image: opt blob;
   name: text;
   royalties: opt nat16;
   royaltyRecipient: opt Account;
   supplyCap: opt nat;
   symbol: text;
 };
type CollectMetricsRequestType = 
 variant {
   force;
   normal;
 };
type Category = 
 variant {
   Avatar;
   Chest;
   Trophy;
   Unit: Unit;
 };
type CanisterMetricsData = 
 variant {
   daily: vec DailyMetricsData;
   hourly: vec HourlyMetricsData;
 };
type CanisterMetrics = record {data: CanisterMetricsData;};
type CanisterMemoryAggregatedData = vec nat64;
type CanisterLogResponse = 
 variant {
   messages: CanisterLogMessages;
   messagesInfo: CanisterLogMessagesInfo;
 };
type CanisterLogRequest = 
 variant {
   getLatestMessages: GetLatestLogMessagesParameters;
   getMessages: GetLogMessagesParameters;
   getMessagesInfo;
 };
type CanisterLogMessagesInfo = 
 record {
   count: nat32;
   features: vec opt CanisterLogFeature;
   firstTimeNanos: opt Nanos;
   lastTimeNanos: opt Nanos;
 };
type CanisterLogMessages = 
 record {
   data: vec LogMessagesData;
   lastAnalyzedMessageTimeNanos: opt Nanos;
 };
type CanisterLogFeature = 
 variant {
   filterMessageByContains;
   filterMessageByRegex;
 };
type CanisterHeapMemoryAggregatedData = vec nat64;
type CanisterCyclesAggregatedData = vec nat64;
type CallError = 
 variant {
   AlreadyExistTokenId;
   GenericError;
   InvalidRecipient;
   InvalidTokenId;
   SupplyCapOverflow;
   Unauthorized;
 };
type BurnArgs = 
 record {
   amount: Balance;
   created_at_time: opt nat64;
   from_subaccount: opt Subaccount;
   memo: opt blob;
 };
type Burn = 
 record {
   amount: Balance;
   created_at_time: opt nat64;
   from: Account__1;
   memo: opt blob;
 };
type BasicStats = record {playerStats: vec PlayerStats;};
type BasicMetadata = 
 record {
   damage: nat;
   health: nat;
   level: nat;
 };
type BalanceResult = 
 variant {
   Err: CallError;
   Ok: nat;
 };
type Balance = nat;
type AverageStats = 
 record {
   averageDamageDealt: nat;
   averageEnergyGenerated: nat;
   averageEnergyUsed: nat;
   averageEnergyWasted: nat;
   averageKills: nat;
   averageXpEarned: nat;
 };
type AvatarID = nat;
type Avatar = 
 record {
   description: text;
   id: nat;
 };
type ArchivedTransaction = 
 record {
   callback: QueryArchiveFn;
   length: nat;
   start: TxIndex;
 };
type ApprovalReceipt = 
 variant {
   Err: ApprovalError;
   Ok: ApprovalId;
 };
type ApprovalId = nat;
type ApprovalError = 
 variant {
   GenericError: record {
                   error_code: nat;
                   message: text;
                 };
   TemporarilyUnavailable: record {};
   TooOld;
   Unauthorized: record {token_ids: vec TokenId;};
 };
type ApprovalArgs = 
 record {
   created_at_time: opt nat64;
   expires_at: opt nat64;
   from_subaccount: opt Subaccount;
   memo: opt blob;
   spender: Account;
   token_ids: opt vec TokenId;
 };
type AdvancedSettings = 
 record {
   burned_tokens: Balance;
   permitted_drift: Timestamp;
   transaction_window: Timestamp;
 };
type AdminFunction = 
 variant {
   BurnToken: record {
                opt Account;
                Account;
                TokenId;
                nat64;
              };
   CreateMission:
    record {
      text;
      MissionCategory;
      MissionType;
      RewardType;
      nat;
      nat;
      nat64;
    };
   CreateMissionsPeriodically;
   GetCollectionOwner: Account;
   GetInitArgs: CollectionInitArgs;
   MintChest: record {
                principal;
                nat;
              };
 };
