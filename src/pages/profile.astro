        { title: "Shield Optimizer", desc: "Regenerated over 1,000,000 shield points in combat." },
        { title: "Hyperdrive Overclock", desc: "Achieved over 150% standard warp speed." }
      ],
      inventory: [
        { name: "Repair Corvette", rarity: "Common", desc: "Support craft with nano-weld capabilities.", img: "/assets/starter-ship.webp" }
      ]
    },
    {
      name: "ZEPHYR_WIND",
      title: "Stellar Pathfinder",
      level: 50,
      xp: 5,
      avatar: "/assets/avatar.webp",
      stake: "150,000 SPIRAL",
      claimable: "6,000 SPIRAL",
      addresses: {
        evm: "0x50C...112e",
        sol: "Path...445z",
        btc: "bc1p...889x",
        icp: "jjjjj-jj"
      },
      achievements: [
        { title: "Sector Cartographer", desc: "Fully scanned and mapped 100 unexplored systems." },
        { title: "Stellar Cartographer", desc: "Discovered a hidden wormhole anomaly." }
      ],
      inventory: [
        { name: "Explorer Vessel", rarity: "Rare", desc: "Long-range research and survey shuttle.", img: "/assets/starter-ship.webp" }
      ]
    }
  ];

  let currentIndex = 0;

  // DOM selectors
  const btnPrev = document.getElementById('btn-prev');
  const btnNext = document.getElementById('btn-next');
  const indexDisplay = document.getElementById('current-index-display');
  const pName = document.getElementById('player-name');
  const pTitle = document.getElementById('player-title');
  const pLevel = document.getElementById('player-level');
  const pXpBar = document.getElementById('player-xp-bar');
  const pStake = document.getElementById('player-stake');
  const pClaimable = document.getElementById('player-claimable');
  
  // Addresses selectors
  const addrEvm = document.getElementById('player-addr-evm');
  const addrSol = document.getElementById('player-addr-sol');
  const addrBtc = document.getElementById('player-addr-btc');
  const addrIcp = document.getElementById('player-addr-icp');

  // Containers
  const achContainer = document.getElementById('achievements-container');
  const invContainer = document.getElementById('inventory-container');

  const updateProfile = (idx: number) => {
    const p = players[idx];
    if (!p) return;

    // Index display
    if (indexDisplay) indexDisplay.innerText = (idx + 1).toString();

    // Text details
    if (pName) pName.innerText = p.name;
    if (pTitle) pTitle.innerText = p.title;
    if (pLevel) pLevel.innerText = p.level.toString();
    if (pXpBar) pXpBar.style.width = `${p.xp}%`;
    if (pStake) pStake.innerText = p.stake;
    if (pClaimable) pClaimable.innerText = p.claimable;

    // Cryptographic Addresses
    if (addrEvm) addrEvm.innerText = p.addresses.evm;
    if (addrSol) addrSol.innerText = p.addresses.sol;
    if (addrBtc) addrBtc.innerText = p.addresses.btc;
    if (addrIcp) addrIcp.innerText = p.addresses.icp;

    // Populate Achievements
    if (achContainer) {
      achContainer.innerHTML = '';
      p.achievements.forEach(ach => {
        const item = document.createElement('div');
        item.className = "bg-white/5 border border-white/5 hover:border-cyan-500/20 p-3 rounded-lg relative overflow-hidden flex flex-col justify-center transition-all duration-300";
        item.innerHTML = `
          <div class="absolute top-0 right-0 w-1.5 h-1.5 border-t border-r border-cyan-500/30"></div>
          <span class="text-white font-bold text-xs uppercase tracking-tight">${ach.title}</span>
          <p class="text-[10px] text-slate-400 font-light leading-snug mt-1">${ach.desc}</p>
        `;
        achContainer.appendChild(item);
      });
    }

    // Populate Inventory
    if (invContainer) {
      invContainer.innerHTML = '';
      p.inventory.forEach(inv => {
        const isMythic = inv.rarity === "Mythic";
        const isLegendary = inv.rarity === "Legendary";
        const isEpic = inv.rarity === "Epic";
        const isRare = inv.rarity === "Rare";
        
        let borderGlow = "border-white/5 hover:border-white/15";
        let textGlow = "text-slate-400";
        let shadowGlow = "";
        
        if (isMythic) {
          borderGlow = "border-purple-500/30 hover:border-purple-400/50";
          textGlow = "text-purple-400";
          shadowGlow = "shadow-[0_0_15px_rgba(168,85,247,0.15)]";
        } else if (isLegendary) {
          borderGlow = "border-amber-500/30 hover:border-amber-400/50";
          textGlow = "text-amber-400";
          shadowGlow = "shadow-[0_0_15px_rgba(245,158,11,0.15)]";
        } else if (isEpic) {
          borderGlow = "border-indigo-500/30 hover:border-indigo-400/50";
          textGlow = "text-indigo-400";
          shadowGlow = "shadow-[0_0_15px_rgba(99,102,241,0.15)]";
        } else if (isRare) {
          borderGlow = "border-cyan-500/30 hover:border-cyan-400/50";
          textGlow = "text-cyan-400";
          shadowGlow = "shadow-[0_0_15px_rgba(6,182,212,0.15)]";
        }

        const item = document.createElement('div');
        item.className = `bg-slate-950/40 border p-3 rounded-lg flex flex-col items-center text-center transition-all duration-300 hover:scale-[1.02] ${borderGlow} ${shadowGlow}`;
        item.innerHTML = `
          <!-- Mini 3D Render -->
          <div class="relative w-12 h-12 flex items-center justify-center mb-2">
            <img src="${inv.img}" alt="${inv.name}" class="max-w-full max-h-full object-contain ${isMythic || isLegendary ? 'animate-bounce-slow' : ''}" />
          </div>
          <span class="text-[10px] uppercase tracking-wider font-extrabold text-white leading-none">${inv.name}</span>
          <span class="text-[8px] font-mono uppercase tracking-widest mt-1 ${textGlow}">${inv.rarity}</span>
        `;
        invContainer.appendChild(item);
      });
    }
  };

  // Nav actions
  btnPrev?.addEventListener('click', () => {
    currentIndex = currentIndex === 0 ? players.length - 1 : currentIndex - 1;
    updateProfile(currentIndex);
  });

  btnNext?.addEventListener('click', () => {
    currentIndex = currentIndex === players.length - 1 ? 0 : currentIndex + 1;
    updateProfile(currentIndex);
  });

  // Initial load
  updateProfile(0);
</script>

<style>
  /* Bounce animations for legendary items */
  @keyframes bounce-slow {
    0%, 100% { transform: translateY(0px) rotate(0deg); }
    50% { transform: translateY(-4px) rotate(1deg); }
  }
  .animate-bounce-slow {
    animation: bounce-slow 4s ease-in-out infinite;
  }

  /* Scrollbars inside profile container */
  .scrollbar-thin::-webkit-scrollbar {
    width: 4px;
    height: 4px;
  }
  .scrollbar-thin::-webkit-scrollbar-track {
    background: transparent;
  }
  .scrollbar-thin::-webkit-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.1);
    border-radius: 9999px;
  }
  .scrollbar-thin::-webkit-scrollbar-thumb:hover {
    background: rgba(15, 185, 253, 0.3);
  }
</style>
</Layout>
