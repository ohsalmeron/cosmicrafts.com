---
import Layout from '../layouts/Layout.astro';
import Starfield from '../components/Starfield.astro';
import Header from '../components/Header.astro';
---

<Layout title="Cosmicrafts | Player Profile">
  <!-- Viewport-Locked Container -->
  <div class="fixed inset-0 h-screen w-screen overflow-hidden flex flex-col justify-between p-6 md:p-10 select-none z-10 bg-[#020208]">
    <!-- Starfield Background -->
    <Starfield />

    <!-- Header component -->
    <Header />

    <!-- Main Profile Card Content Area -->
    <main class="w-full max-w-7xl mx-auto flex-1 flex flex-col my-4 overflow-hidden z-10 justify-center">
      <!-- Top controls / Selector -->
      <div class="w-full flex justify-between items-center mb-4 font-mono text-[10px] md:text-xs">
        <button id="btn-prev" class="px-4 py-2 bg-white/5 border border-white/5 hover:border-cyan-500/30 hover:bg-cyan-950/20 text-slate-400 hover:text-white rounded-lg transition-all duration-300 transform active:scale-95">
          ◀ PREV PROFILE
        </button>
        <span class="text-slate-500 uppercase tracking-widest">[ CYCLING MOCK PROFILES: <span id="current-index-display" class="text-cyan-400">1</span> / 10 ]</span>
        <button id="btn-next" class="px-4 py-2 bg-white/5 border border-white/5 hover:border-cyan-500/30 hover:bg-cyan-950/20 text-slate-400 hover:text-white rounded-lg transition-all duration-300 transform active:scale-95">
          NEXT PROFILE ▶
        </button>
      </div>

      <!-- Main Steam Card Frame (Transition Enabled) -->
      <div id="profile-frame" class="w-full max-w-5xl mx-auto p-6 md:p-8 flex flex-col md:flex-row gap-6 md:gap-10 items-stretch transition-all duration-300">
        <!-- Left side: Player Basic Info -->
        <div class="w-full md:w-80 flex flex-col justify-between border-b md:border-b-0 md:border-r border-white/5 pb-6 md:pb-0 md:pr-10">
          <div class="space-y-6">
            <!-- Avatar & Username block -->
            <div class="flex items-center space-x-4">
              <!-- Avatar Circle -->
              <div class="relative w-16 h-16 rounded-full border-2 border-cyan-500/30 overflow-hidden shadow-[0_0_20px_rgba(6,182,212,0.15)] flex-shrink-0">
                <img id="player-avatar" src="/assets/avatars/Avatar_01.webp" alt="Avatar" class="w-full h-full object-cover" />
              </div>
              <div class="flex flex-col text-left">
                <h2 id="player-name" class="text-lg md:text-2xl font-black text-white uppercase tracking-tight">BIZKIT_0x1337</h2>
                <span id="player-title" class="text-[10px] text-cyan-400 font-mono tracking-widest uppercase">Galactic Emperor</span>
              </div>
            </div>

            <!-- Level Progression -->
            <div class="space-y-1.5 font-mono text-[10px] text-left">
              <div class="flex justify-between text-slate-400 uppercase">
                <span>Level: <span id="player-level" class="text-white font-bold">99</span></span>
                <span>XP: 100%</span>
              </div>
              <div class="w-full h-2 bg-slate-900 border border-white/5 rounded-full overflow-hidden">
                <div id="player-xp-bar" class="h-full bg-gradient-to-r from-cyan-500 to-indigo-500 rounded-full" style="width: 100%"></div>
              </div>
            </div>

            <!-- Staking & Token Metrics -->
            <div class="bg-white/5 border border-white/5 rounded-lg p-4 font-mono text-xs text-left space-y-2.5">
              <div class="text-[10px] text-slate-500 tracking-wider uppercase border-b border-white/5 pb-1">[ VAULT ]</div>
              <div class="flex justify-between">
                <span class="text-slate-400">Locked Stake:</span>
                <span id="player-stake" class="text-white font-bold">70,000,000 SPIRAL</span>
              </div>
              <div class="flex justify-between">
                <span class="text-slate-400">Claimable:</span>
                <span id="player-claimable" class="text-cyan-400 font-bold">12,500 SPIRAL</span>
              </div>
            </div>
          </div>

          <!-- Subtle Cryptographic Identities -->
          <div class="relative pt-6 border-t border-white/5 mt-6 text-left">
            <span class="text-[9px] text-slate-500 font-mono block mb-2 uppercase">[ IDENTITIES ]</span>
            <div class="flex space-x-2" id="identities-container">
              <!-- Dynamically rendered via JS -->
            </div>
          </div>
        </div>
      </div>

      <!-- Right side: Achievements and Inventory -->
      <div class="flex-1 flex flex-col gap-6 overflow-y-auto max-h-[55vh] md:max-h-[500px] scrollbar-thin text-left pr-2">
          <!-- Achievements Section -->
          <div class="space-y-3">
            <h3 class="text-xs text-cyan-400 font-mono tracking-widest uppercase border-b border-white/5 pb-2">[ ACHIEVEMENTS ]</h3>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3" id="achievements-container">
              <!-- Dynamically populated via JS -->
            </div>
          </div>

          <!-- Inventory Section (Scrollable Grid Enabled) -->
          <div class="space-y-3">
            <h3 class="text-xs text-cyan-400 font-mono tracking-widest uppercase border-b border-white/5 pb-2">[ INVENTORY ]</h3>
            <div class="grid grid-cols-2 sm:grid-cols-3 gap-3 max-h-[290px] overflow-y-auto pr-1 scrollbar-thin" id="inventory-container">
              <!-- Dynamically populated via JS as vertical OpenSea-like NFT cards -->
            </div>
          </div>
        </div>
      </div>
    </main>

    <!-- Floating High-Detail NFT Visor / Modal -->
    <div id="nft-visor-modal" class="fixed inset-0 z-[9999] hidden items-center justify-center p-4 bg-slate-950/50 backdrop-blur-md">
      <!-- Backdrop Click Close -->
      <div class="absolute inset-0 z-0" id="nft-visor-backdrop"></div>
      
      <!-- Visor Content Panel -->
      <div class="relative w-full max-w-3xl backdrop-blur-2xl bg-slate-950/85 border border-cyan-500/20 rounded-2xl p-6 md:p-8 shadow-[0_0_80px_rgba(6,182,212,0.2)] flex flex-col md:flex-row gap-6 md:gap-10 z-10 select-none overflow-hidden text-left">
        <!-- Corner Brackets -->
        <!-- Left Column: Visual Render -->
        <div class="w-full md:w-72 flex flex-col items-center justify-center bg-[radial-gradient(circle_at_center,rgba(6,182,212,0.12)_0%,transparent_75%)] border border-white/5 rounded-xl p-6 relative">
          <!-- Rarity Badge -->
          <span id="visor-rarity" class="absolute top-3 left-3 px-2 py-0.5 rounded text-[8px] font-mono font-black uppercase tracking-widest bg-slate-950 border border-white/5">
            LEGENDARY
          </span>
          <img id="visor-img" src="/assets/starter-ship.webp" alt="Visor Render" class="max-w-[85%] max-h-56 object-contain drop-shadow-[0_10px_35px_rgba(15,185,253,0.3)] animate-float" />
        </div>

        <!-- Right Column: Massive Technical Specifications (Cagadero de Info) -->
        <div class="flex-1 flex flex-col justify-between overflow-y-auto max-h-[60vh] md:max-h-[350px] scrollbar-thin font-mono text-[10px] text-slate-400 space-y-4">
          <div>
            <div class="flex items-center justify-between border-b border-white/5 pb-2 mb-3">
              <span class="text-cyan-400 text-xs font-black uppercase">[ TELEMETRY DETAILED READOUT ]</span>
              <button id="btn-close-visor" class="text-[10px] hover:text-white transition-colors">CLOSE ✕</button>
            </div>

            <!-- Title & ID -->
            <div class="space-y-1 mb-4">
              <h1 id="visor-name" class="text-xl md:text-2xl font-black text-white uppercase tracking-tight leading-none">Void Dreadnought</h1>
              <span id="visor-serial" class="text-slate-500 text-xs">ID: #0001</span>
            </div>

            <!-- Spec Grid -->
            <div class="grid grid-cols-2 gap-x-6 gap-y-2 bg-white/5 border border-white/5 rounded-lg p-3 mb-4">
              <div class="flex justify-between border-b border-white/5 pb-1">
                <span class="text-slate-500">FIREPOWER:</span>
                <span id="visor-power" class="text-white font-bold">98%</span>
              </div>
              <div class="flex justify-between border-b border-white/5 pb-1">
                <span class="text-slate-500">SPEED_INDEX:</span>
                <span id="visor-speed" class="text-white font-bold">9.5LY</span>
              </div>
              <div class="flex justify-between border-b border-white/5 pb-1">
                <span class="text-slate-500">HULL PLATING:</span>
                <span class="text-cyan-400">NANO-CARBON</span>
              </div>
              <div class="flex justify-between border-b border-white/5 pb-1">
                <span class="text-slate-500">SHIELD TYPE:</span>
                <span class="text-cyan-400">AEGIS MK-V</span>
              </div>
              <div class="flex justify-between col-span-2 pt-1">
                <span class="text-slate-500">EST_VALUATION:</span>
                <span id="visor-val" class="text-cyan-400 font-black">150,000 SPIRAL</span>
              </div>
            </div>

            <!-- Web3 Ledger data (El Cagadero de Blockchain Info) -->
            <div class="space-y-1.5 border-t border-white/5 pt-3">
              <span class="text-[8px] text-slate-500 uppercase font-black tracking-widest">[ BLOCKCHAIN LEDGER DATA ]</span>
              <div class="flex justify-between">
                <span>CONTRACT STANDARD:</span>
                <span class="text-slate-300">ERC-1155 (COSMIC_STORE)</span>
              </div>
              <div class="flex justify-between">
                <span>METADATA STORAGE:</span>
                <span class="text-slate-300">DECENTRALIZED IPFS</span>
              </div>
              <div class="flex justify-between">
                <span>MINT_BLOCK:</span>
                <span class="text-slate-300">#19823481 (ETH_MAINNET)</span>
              </div>
              <div class="flex flex-col gap-0.5 mt-2">
                <span class="text-slate-500 text-[8px]">[ TRANSACTION_HASH ]</span>
                <span class="text-cyan-400 text-[9px] select-text break-all">0x9e12bf4fa3198083933635ad420ec2bfce4b9211fb33c62</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Footer -->
    <footer class="w-full max-w-7xl mx-auto flex justify-between items-center z-10 font-mono text-[9px] text-slate-600">
      <a href="https://worldofunreal.com/" target="_blank" class="hover:text-cyan-400 transition-colors uppercase">&copy; 2026 WORLD OF UNREAL. PROFILE HUB V1.0</a>
      <span>SECURE ENCRYPTED CONNECTION</span>
    </footer>
  </div>
</Layout>

<script>
  // 10 Mock Profiles Database
  const players = [
    {
