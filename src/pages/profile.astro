              ${ident.label}: <span class="text-cyan-400">${ident.addr}</span>
            </div>
          `;
          identContainer.appendChild(item);
        });
      }

      // Populate Achievements
      if (achContainer) {
        achContainer.innerHTML = '';
        p.achievements.forEach(ach => {
          const item = document.createElement('div');
          item.className = "bg-white/5 border border-white/5 p-3 rounded-lg relative overflow-hidden flex flex-col justify-center";
          item.innerHTML = `
            <div class="absolute top-0 right-0 w-1.5 h-1.5 border-t border-r border-cyan-500/30"></div>
            <span class="text-white font-bold text-xs uppercase tracking-tight">${ach.title}</span>
            <p class="text-[10px] text-slate-400 font-light leading-snug mt-1">${ach.desc}</p>
          `;
          achContainer.appendChild(item);
        });
      }

      // Populate Inventory (Vertical Collectible/NFT Card Format)
      if (invContainer) {
        invContainer.innerHTML = '';
        p.inventory.forEach(inv => {
          const isMythic = inv.rarity === "Mythic";
          const isLegendary = inv.rarity === "Legendary";
          const isEpic = inv.rarity === "Epic";
          const isRare = inv.rarity === "Rare";
          
          let borderGlow = "border-white/5 hover:border-cyan-500/25";
          let textGlow = "text-slate-400";
          let shadowGlow = "";
          
          if (isMythic) {
            borderGlow = "border-purple-500/20 hover:border-purple-400/40 bg-purple-950/5";
            textGlow = "text-purple-400";
            shadowGlow = "shadow-[0_0_15px_rgba(168,85,247,0.1)]";
          } else if (isLegendary) {
            borderGlow = "border-amber-500/20 hover:border-amber-400/40 bg-amber-950/5";
            textGlow = "text-amber-400";
            shadowGlow = "shadow-[0_0_15px_rgba(245,158,11,0.1)]";
          } else if (isEpic) {
            borderGlow = "border-indigo-500/20 hover:border-indigo-400/40 bg-indigo-950/5";
            textGlow = "text-indigo-400";
            shadowGlow = "shadow-[0_0_15px_rgba(99,102,241,0.1)]";
          } else if (isRare) {
            borderGlow = "border-cyan-500/20 hover:border-cyan-400/40 bg-cyan-950/5";
            textGlow = "text-cyan-400";
            shadowGlow = "shadow-[0_0_15px_rgba(6,182,212,0.1)]";
          }

          const item = document.createElement('div');
          item.className = `bg-slate-950/65 border rounded-xl overflow-hidden flex flex-col transition-colors duration-200 relative ${borderGlow} ${shadowGlow} group`;
          item.innerHTML = `
            <!-- Asset Thumbnail with Cyber Grid Background -->
            <div class="relative w-full aspect-square bg-[radial-gradient(circle_at_center,rgba(6,182,212,0.1)_0%,transparent_70%)] border-b border-white/5 flex items-center justify-center p-3">
              <!-- Floating Rarity Tag -->
              <span class="absolute top-2 left-2 px-1.5 py-0.5 rounded text-[7px] font-mono font-black uppercase tracking-widest bg-slate-950/85 border border-white/5 ${textGlow}">
                ${inv.rarity}
              </span>
              
              <img src="${inv.img}" alt="${inv.name}" class="max-w-[80%] max-h-[80%] object-contain drop-shadow-[0_4px_10px_rgba(0,0,0,0.5)] ${isMythic || isLegendary ? 'animate-bounce-slow' : ''}" />
            </div>
            
            <!-- Asset Details -->
            <div class="p-3 flex flex-col text-left space-y-2 font-mono">
              <div class="flex flex-col gap-0.5">
                <span class="text-[9px] text-white font-extrabold tracking-tight uppercase leading-none truncate">${inv.name}</span>
                <span class="text-[7px] text-slate-500 leading-none">ID: #${inv.serial}</span>
              </div>
              
              <!-- Stats readouts -->
              <div class="flex justify-between items-center text-[7px] text-slate-400 bg-white/5 rounded p-1.5 border border-white/5">
                <span>PWR: ${inv.power}%</span>
                <span>SPD: ${inv.speed}LY</span>
              </div>
              
              <!-- Value / Price -->
              <div class="flex items-center justify-between border-t border-white/5 pt-2 mt-1">
                <span class="text-[7px] text-slate-500 uppercase font-black">VALUE:</span>
                <div class="flex items-center gap-1">
                  <img src="/assets/icons/spiral.svg" alt="SPIRAL" class="w-2.5 h-2.5" />
                  <span class="text-[9px] text-cyan-400 font-black leading-none">${inv.value}</span>
                </div>
              </div>
            </div>
          `;
          invContainer.appendChild(item);
        });
      }

      // Finish transition: fade back in
      profileFrame?.classList.remove('opacity-0', 'scale-[0.985]', 'blur-[1.5px]');
    }, 150);
  };

  // Nav actions
  btnPrev?.addEventListener('click', () => {
    currentIndex = currentIndex === 0 ? players.length - 1 : currentIndex - 1;
    updateProfile(currentIndex);
  });

  btnNext?.addEventListener('click', () => {
    currentIndex = currentIndex === players.length - 1 ? 0 : currentIndex + 1;
    updateProfile(currentIndex);
  });

  // Initial load
  updateProfile(0);
</script>

<style>
  /* Bounce animations for legendary items */
  @keyframes bounce-slow {
    0%, 100% { transform: translateY(0px) rotate(0deg); }
    50% { transform: translateY(-4px) rotate(1deg); }
  }
  .animate-bounce-slow {
    animation: bounce-slow 4s ease-in-out infinite;
  }

  /* Scrollbars inside profile container */
  .scrollbar-thin::-webkit-scrollbar {
    width: 4px;
    height: 4px;
  }
  .scrollbar-thin::-webkit-scrollbar-track {
    background: transparent;
  }
  .scrollbar-thin::-webkit-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.1);
    border-radius: 9999px;
  }
  .scrollbar-thin::-webkit-scrollbar-thumb:hover {
    background: rgba(15, 185, 253, 0.3);
  }
</style>
</Layout>
