      claimable: "6,000 SPIRAL",
      identities: [
        { type: "sol", icon: "/assets/icons/phantom.svg", label: "SOL", addr: "Path...445z" },
        { type: "btc", icon: "/assets/icons/xverse.svg", label: "BTC", addr: "bc1p...889x" }
      ],
      achievements: [
        { title: "Sector Cartographer", desc: "Fully scanned and mapped 100 unexplored systems." },
        { title: "Stellar Cartographer", desc: "Discovered a hidden wormhole anomaly." }
      ]
    }
  ];

  // Base list of beautiful ship & planet designs to dynamically seed rich inventories (7 to 23 items per player)
  const baseAssets = [
    { name: "Void Interceptor", img: "/assets/starter-ship.webp", type: "ship" },
    { name: "Nebula Interceptor", img: "/assets/starter-ship.webp", type: "ship" },
    { name: "Dreadnought Destroyer", img: "/assets/starter-ship.webp", type: "ship" },
    { name: "Sovereign Cruiser", img: "/assets/starter-ship.webp", type: "ship" },
    { name: "Aegis Escort", img: "/assets/starter-ship.webp", type: "ship" },
    { name: "Repair Corvette", img: "/assets/starter-ship.webp", type: "ship" },
    { name: "Flagship Carrier", img: "/assets/starter-ship.webp", type: "ship" },
    { name: "Planet Genesis", img: "/assets/planet.webp", type: "planet" },
    { name: "Dyson Sphere Core", img: "/assets/planet.webp", type: "planet" },
    { name: "Nebula Star Station", img: "/assets/planet.webp", type: "planet" },
    { name: "Frozen Core", img: "/assets/planet.webp", type: "planet" },
    { name: "Volcano Forge", img: "/assets/planet.webp", type: "planet" }
  ];

  const rarities = ["Mythic", "Legendary", "Epic", "Rare", "Common"];

  // Helper to dynamically generate rich, unique, scrolled inventories (between 7 and 23 items per player)
  const generateInventoryForPlayer = (idx: number) => {
    // Deterministic random seed based on player name length & index
    const count = 7 + ((idx * 7 + 13) % 17); // Generates between 7 and 23 items consistently
    const inventory = [];
    
    for (let i = 0; i < count; i++) {
      const assetIdx = (idx * 5 + i * 13) % baseAssets.length;
      const asset = baseAssets[assetIdx];
      const rarityIdx = (idx * 3 + i * 7) % rarities.length;
      const rarity = rarities[rarityIdx];
      
      const serial = String(100 + (idx * 23 + i * 47) % 900).padStart(4, '0');
      const power = 30 + (idx * 11 + i * 17) % 71;
      const speed = asset.type === "planet" ? 0.0 : (5 + (idx * 3 + i * 9) % 11);
      const value = (100 + (idx * 250 + i * 450) % 95000).toLocaleString();

      inventory.push({
        name: asset.name,
        rarity,
        serial,
        power,
        speed,
        value,
        img: asset.img
      });
    }
    return inventory;
  };

  let currentIndex = 0;

  // DOM selectors
  const btnPrev = document.getElementById('btn-prev');
  const btnNext = document.getElementById('btn-next');
  const indexDisplay = document.getElementById('current-index-display');
  const profileFrame = document.getElementById('profile-frame');
  const pAvatar = document.getElementById('player-avatar') as HTMLImageElement;
  const pName = document.getElementById('player-name');
  const pTitle = document.getElementById('player-title');
  const pLevel = document.getElementById('player-level');
  const pXpBar = document.getElementById('player-xp-bar');
  const pStake = document.getElementById('player-stake');
  const pClaimable = document.getElementById('player-claimable');
  
  // Containers
  const identContainer = document.getElementById('identities-container');
  const achContainer = document.getElementById('achievements-container');
  const invContainer = document.getElementById('inventory-container');

  // Visor selectors
  const visorModal = document.getElementById('nft-visor-modal');
  const visorBackdrop = document.getElementById('nft-visor-backdrop');
  const btnCloseVisor = document.getElementById('btn-close-visor');
  const visorImg = document.getElementById('visor-img') as HTMLImageElement;
  const visorRarity = document.getElementById('visor-rarity');
  const visorName = document.getElementById('visor-name');
  const visorSerial = document.getElementById('visor-serial');
  const visorPower = document.getElementById('visor-power');
  const visorSpeed = document.getElementById('visor-speed');
  const visorVal = document.getElementById('visor-val');

  // Open details visor modal (Cagadero de Info Detailed view)
  const openVisor = (item: any) => {
    if (!visorModal) return;
    
    if (visorImg) visorImg.src = item.img;
    if (visorRarity) {
      visorRarity.innerText = item.rarity;
      // Change color according to rarity
      visorRarity.className = `absolute top-3 left-3 px-2 py-0.5 rounded text-[8px] font-mono font-black uppercase tracking-widest bg-slate-950 border border-white/5 ${
        item.rarity === "Mythic" ? "text-purple-400 border-purple-500/20" :
        item.rarity === "Legendary" ? "text-amber-400 border-amber-500/20" :
        item.rarity === "Epic" ? "text-indigo-400 border-indigo-500/20" :
        item.rarity === "Rare" ? "text-cyan-400 border-cyan-500/20" : "text-slate-400"
      }`;
    }
    if (visorName) visorName.innerText = item.name;
    if (visorSerial) visorSerial.innerText = `ID: #${item.serial}`;
    if (visorPower) visorPower.innerText = `${item.power}%`;
    if (visorSpeed) visorSpeed.innerText = `${item.speed}LY`;
    if (visorVal) visorVal.innerText = `${item.value} SPIRAL`;

    visorModal.classList.remove('hidden');
    visorModal.classList.add('flex');
  };

  // Close Visor
  const closeVisor = () => {
    visorModal?.classList.add('hidden');
    visorModal?.classList.remove('flex');
  };
  btnCloseVisor?.addEventListener('click', closeVisor);
  visorBackdrop?.addEventListener('click', closeVisor);

  const updateProfile = (idx: number) => {
    const p = players[idx];
    if (!p) return;

    // Trigger high-performance space warp fade-and-zoom transition (GPU bound)
    profileFrame?.classList.add('opacity-0', 'scale-[0.985]', 'blur-[1.5px]');

    setTimeout(() => {
      // Index display
      if (indexDisplay) indexDisplay.innerText = (idx + 1).toString();

      // Basic details
      if (pAvatar) pAvatar.src = p.avatar;
      if (pName) pName.innerText = p.name;
      if (pTitle) pTitle.innerText = p.title;
      if (pLevel) pLevel.innerText = p.level.toString();
      if (pXpBar) pXpBar.style.width = `${p.xp}%`;
      if (pStake) pStake.innerText = p.stake;
      if (pClaimable) pClaimable.innerText = p.claimable;

      // Render Cryptographic Identities Dynamically
      if (identContainer) {
        identContainer.innerHTML = '';
        p.identities.forEach(ident => {
          const item = document.createElement('div');
          item.className = "p-1.5 rounded bg-white/5 border border-white/5 cursor-pointer hover:border-cyan-500/20 hover:bg-cyan-950/10 transition-colors duration-200 relative group";
          item.innerHTML = `
            <img src="${ident.icon}" alt="${ident.label}" class="w-4 h-4" />
            <div class="absolute bottom-8 left-0 hidden group-hover:block bg-slate-950 border border-cyan-500/20 rounded px-2.5 py-1 text-[9px] font-mono text-white whitespace-nowrap z-50">
              ${ident.label}: <span class="text-cyan-400">${ident.addr}</span>
            </div>
          `;
          identContainer.appendChild(item);
        });
      }

      // Populate Achievements
      if (achContainer) {
        achContainer.innerHTML = '';
        p.achievements.forEach(ach => {
          const item = document.createElement('div');
          item.className = "bg-white/5 border border-white/5 p-3 rounded-lg relative overflow-hidden flex flex-col justify-center";
          item.innerHTML = `
            <div class="absolute top-0 right-0 w-1.5 h-1.5 border-t border-r border-cyan-500/30"></div>
            <span class="text-white font-bold text-xs uppercase tracking-tight">${ach.title}</span>
            <p class="text-[10px] text-slate-400 font-light leading-snug mt-1">${ach.desc}</p>
          `;
          achContainer.appendChild(item);
        });
      }

      // Populate Procedural Rich Inventories (7 to 23 items to test scroll/hover)
      if (invContainer) {
        invContainer.innerHTML = '';
        const playerInventory = generateInventoryForPlayer(idx);
        
        playerInventory.forEach(inv => {
          const isMythic = inv.rarity === "Mythic";
          const isLegendary = inv.rarity === "Legendary";
          const isEpic = inv.rarity === "Epic";
          const isRare = inv.rarity === "Rare";
          
          let borderGlow = "border-white/5 hover:border-cyan-500/25";
          let textGlow = "text-slate-400";
          let shadowGlow = "";
          
          if (isMythic) {
            borderGlow = "border-purple-500/15 hover:border-purple-400/40 bg-purple-950/5";
            textGlow = "text-purple-400";
            shadowGlow = "shadow-[0_0_15px_rgba(168,85,247,0.1)]";
          } else if (isLegendary) {
            borderGlow = "border-amber-500/15 hover:border-amber-400/40 bg-amber-950/5";
            textGlow = "text-amber-400";
            shadowGlow = "shadow-[0_0_15px_rgba(245,158,11,0.1)]";
          } else if (isEpic) {
            borderGlow = "border-indigo-500/15 hover:border-indigo-400/40 bg-indigo-950/5";
            textGlow = "text-indigo-400";
            shadowGlow = "shadow-[0_0_15px_rgba(99,102,241,0.1)]";
          } else if (isRare) {
            borderGlow = "border-cyan-500/15 hover:border-cyan-400/40 bg-cyan-950/5";
            textGlow = "text-cyan-400";
            shadowGlow = "shadow-[0_0_15px_rgba(6,182,212,0.1)]";
          }

          const item = document.createElement('div');
          item.className = `bg-slate-950/40 border p-3 rounded-lg flex flex-col items-center text-center cursor-pointer transition-colors duration-200 ${borderGlow} ${shadowGlow} group`;
          item.innerHTML = `
            <!-- Mini Thumbnail with Grid Background -->
            <div class="relative w-full aspect-square bg-[radial-gradient(circle_at_center,rgba(6,182,212,0.08)_0%,transparent_70%)] border-b border-white/5 flex items-center justify-center p-2">
              <span class="absolute top-1.5 left-1.5 px-1.5 py-0.5 rounded text-[6px] font-mono font-black uppercase tracking-widest bg-slate-950/85 border border-white/5 ${textGlow}">
                ${inv.rarity}
              </span>
              <img src="${inv.img}" alt="${inv.name}" class="max-w-[75%] max-h-[75%] object-contain drop-shadow-[0_4px_10px_rgba(0,0,0,0.5)] ${isMythic || isLegendary ? 'animate-bounce-slow' : ''}" />
            </div>
            
            <!-- Details -->
            <div class="p-2 w-full flex flex-col text-left space-y-1.5 font-mono">
              <div class="flex flex-col">
                <span class="text-[9px] text-white font-extrabold tracking-tight uppercase leading-none truncate">${inv.name}</span>
                <span class="text-[7px] text-slate-500 mt-0.5">ID: #${inv.serial}</span>
              </div>
              <div class="flex justify-between items-center text-[6px] text-slate-400 bg-white/5 rounded p-1 border border-white/5">
                <span>PWR: ${inv.power}%</span>
                <span>SPD: ${inv.speed}LY</span>
              </div>
              <div class="flex items-center justify-between border-t border-white/5 pt-1.5 mt-0.5">
                <span class="text-[6px] text-slate-500 uppercase font-black">VAL:</span>
                <div class="flex items-center gap-0.5">
                  <img src="/assets/icons/spiral.svg" alt="SPIRAL" class="w-2 h-2" />
                  <span class="text-[8px] text-cyan-400 font-black leading-none">${inv.value}</span>
                </div>
              </div>
            </div>
          `;

          // Add Details Visor Click Trigger
          item.addEventListener('click', () => {
            openVisor(inv);
          });

          invContainer.appendChild(item);
        });
      }

      // Finish transition: fade back in
      profileFrame?.classList.remove('opacity-0', 'scale-[0.985]', 'blur-[1.5px]');
    }, 150);
  };

  // Nav actions
  btnPrev?.addEventListener('click', () => {
    currentIndex = currentIndex === 0 ? players.length - 1 : currentIndex - 1;
    updateProfile(currentIndex);
  });

  btnNext?.addEventListener('click', () => {
    currentIndex = currentIndex === players.length - 1 ? 0 : currentIndex + 1;
    updateProfile(currentIndex);
  });

  // Initial load
  updateProfile(0);
</script>

<style>
  /* Bounce animations for legendary items */
  @keyframes bounce-slow {
    0%, 100% { transform: translateY(0px) rotate(0deg); }
    50% { transform: translateY(-4px) rotate(1deg); }
  }
  .animate-bounce-slow {
    animation: bounce-slow 4s ease-in-out infinite;
  }

  /* Custom floating space animation for ships in visor */
  @keyframes float-visor {
    0%, 100% { transform: translateY(0px) rotate(0deg); }
    50% { transform: translateY(-10px) rotate(1.5deg); }
  }
  .animate-float {
    animation: float-visor 6s ease-in-out infinite;
  }

  /* Scrollbars inside profile container */
  .scrollbar-thin::-webkit-scrollbar {
    width: 4px;
    height: 4px;
  }
  .scrollbar-thin::-webkit-scrollbar-track {
    background: transparent;
  }
  .scrollbar-thin::-webkit-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.1);
    border-radius: 9999px;
  }
  .scrollbar-thin::-webkit-scrollbar-thumb:hover {
    background: rgba(15, 185, 253, 0.3);
  }
</style>
</Layout>
