---
import Layout from '../layouts/Layout.astro';
import Starfield from '../components/Starfield.astro';
import Header from '../components/Header.astro';
---

<Layout title="Cosmicrafts | Player Profile">
  <div class="fixed inset-0 h-screen w-screen overflow-hidden flex flex-col justify-between p-6 md:p-10 select-none z-10 bg-[#020208]">
    <!-- Starfield Background -->
    <Starfield />

    <!-- Ambient glows -->
    <div class="absolute top-1/4 left-1/4 w-[500px] h-[500px] bg-cyan-500/5 rounded-full blur-[140px] pointer-events-none z-0"></div>
    <div class="absolute bottom-1/4 right-1/4 w-[500px] h-[500px] bg-indigo-500/5 rounded-full blur-[140px] pointer-events-none z-0"></div>

    <!-- Header component -->
    <Header />

    <!-- Main Profile Card Content Area -->
    <main class="w-full max-w-7xl mx-auto flex-1 flex flex-col my-4 overflow-hidden z-10 justify-center">
      <!-- Top controls / Selector -->
      <div class="w-full flex justify-between items-center mb-4 font-mono text-[10px] md:text-xs">
        <button id="btn-prev" class="px-4 py-2 bg-white/5 border border-white/5 hover:border-cyan-500/30 hover:bg-cyan-950/20 text-slate-400 hover:text-white rounded-lg transition-all duration-300 transform active:scale-95">
          ◀ PREV PROFILE
        </button>
        <span class="text-slate-500 uppercase tracking-widest">[ CYCLING MOCK PROFILES: <span id="current-index-display" class="text-cyan-400">1</span> / 10 ]</span>
        <button id="btn-next" class="px-4 py-2 bg-white/5 border border-white/5 hover:border-cyan-500/30 hover:bg-cyan-950/20 text-slate-400 hover:text-white rounded-lg transition-all duration-300 transform active:scale-95">
          NEXT PROFILE ▶
        </button>
      </div>

      <!-- Main Steam Card Frame -->
      <div class="w-full max-w-5xl mx-auto backdrop-blur-lg bg-slate-950/45 border border-cyan-500/10 rounded-xl p-6 md:p-8 shadow-[0_0_50px_rgba(6,182,212,0.06)] relative flex flex-col md:flex-row gap-6 md:gap-10 overflow-hidden items-stretch">
        <!-- Cyber Corner Brackets -->
        <div class="absolute top-0 left-0 w-6 h-6 border-t border-l border-cyan-400/50"></div>
        <div class="absolute top-0 right-0 w-6 h-6 border-t border-r border-cyan-400/50"></div>
        <div class="absolute bottom-0 left-0 w-6 h-6 border-b border-l border-cyan-400/50"></div>
        <div class="absolute bottom-0 right-0 w-6 h-6 border-b border-r border-cyan-400/50"></div>

        <!-- Left side: Player Basic Info / Steam Card -->
        <div class="w-full md:w-80 flex flex-col justify-between border-b md:border-b-0 md:border-r border-white/5 pb-6 md:pb-0 md:pr-10">
          <div class="space-y-6">
            <!-- Avatar & Username block -->
            <div class="flex items-center space-x-4">
              <!-- Avatar Circle -->
              <div class="relative w-16 h-16 rounded-full border-2 border-cyan-500/30 overflow-hidden shadow-[0_0_20px_rgba(6,182,212,0.15)] flex-shrink-0">
                <img id="player-avatar" src="/assets/avatar.webp" alt="Avatar" class="w-full h-full object-cover" />
              </div>
              <div class="flex flex-col text-left">
                <h2 id="player-name" class="text-lg md:text-2xl font-black text-white uppercase tracking-tight">BIZKIT_0x1337</h2>
                <span id="player-title" class="text-[10px] text-cyan-400 font-mono tracking-widest uppercase">Galactic Emperor</span>
              </div>
            </div>

            <!-- Level Progression (Steam Vibe) -->
            <div class="space-y-1.5 font-mono text-[10px] text-left">
              <div class="flex justify-between text-slate-400 uppercase">
                <span>Galactic Level: <span id="player-level" class="text-white font-bold">99</span></span>
                <span>XP: 100%</span>
              </div>
              <div class="w-full h-2 bg-slate-900 border border-white/5 rounded-full overflow-hidden">
                <div id="player-xp-bar" class="h-full bg-gradient-to-r from-cyan-500 to-indigo-500 rounded-full" style="width: 100%"></div>
              </div>
            </div>

            <!-- Staking & Token Metrics readout -->
            <div class="bg-white/5 border border-white/5 rounded-lg p-4 font-mono text-xs text-left space-y-2.5">
              <div class="text-[10px] text-slate-500 tracking-wider uppercase border-b border-white/5 pb-1">[ COSMIC_VAULT ]</div>
              <div class="flex justify-between">
                <span class="text-slate-400">Locked Stake:</span>
                <span id="player-stake" class="text-white font-bold">70,000,000 SPIRAL</span>
              </div>
              <div class="flex justify-between">
                <span class="text-slate-400">Available Claim:</span>
                <span id="player-claimable" class="text-cyan-400 font-bold">12,500 SPIRAL</span>
              </div>
            </div>
          </div>

          <!-- Subtle Cryptographic Tooltip Toggle -->
          <div class="relative pt-6 border-t border-white/5 mt-6 text-left">
            <span class="text-[9px] text-slate-500 font-mono block mb-1 uppercase">[ CRYPTOGRAPHIC_IDENTITIES ]</span>
            <div class="flex space-x-2">
              <div class="p-1.5 rounded bg-white/5 border border-white/5 cursor-pointer hover:border-cyan-500/30 transition-all duration-300 relative group" id="ident-eth">
                <img src="/assets/icons/metamask.svg" alt="ETH" class="w-4 h-4" />
                <div class="absolute bottom-8 left-0 hidden group-hover:block bg-slate-950 border border-cyan-500/20 rounded px-2.5 py-1 text-[9px] font-mono text-white whitespace-nowrap z-50">
                  EVM: <span id="player-addr-evm" class="text-cyan-400">0x71C...9312</span>
                </div>
              </div>
              <div class="p-1.5 rounded bg-white/5 border border-white/5 cursor-pointer hover:border-cyan-500/30 transition-all duration-300 relative group" id="ident-sol">
                <img src="/assets/icons/phantom.svg" alt="SOL" class="w-4 h-4" />
                <div class="absolute bottom-8 left-0 hidden group-hover:block bg-slate-950 border border-cyan-500/20 rounded px-2.5 py-1 text-[9px] font-mono text-white whitespace-nowrap z-50">
                  SOL: <span id="player-addr-sol" class="text-cyan-400">Phan...771a</span>
                </div>
              </div>
              <div class="p-1.5 rounded bg-white/5 border border-white/5 cursor-pointer hover:border-cyan-500/30 transition-all duration-300 relative group" id="ident-btc">
                <img src="/assets/icons/xverse.svg" alt="BTC" class="w-4 h-4" />
                <div class="absolute bottom-8 left-0 hidden group-hover:block bg-slate-950 border border-cyan-500/20 rounded px-2.5 py-1 text-[9px] font-mono text-white whitespace-nowrap z-50">
                  BTC: <span id="player-addr-btc" class="text-cyan-400">bc1p...337f</span>
                </div>
              </div>
              <div class="p-1.5 rounded bg-white/5 border border-white/5 cursor-pointer hover:border-cyan-500/30 transition-all duration-300 relative group" id="ident-icp">
                <img src="/assets/icons/icp.svg" alt="ICP" class="w-4 h-4" />
                <div class="absolute bottom-8 left-0 hidden group-hover:block bg-slate-950 border border-cyan-500/20 rounded px-2.5 py-1 text-[9px] font-mono text-white whitespace-nowrap z-50">
                  ICP: <span id="player-addr-icp" class="text-cyan-400">aaaaa-aa</span>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Right side: Achievements and Galactic Inventory (Scrollable) -->
        <div class="flex-1 flex flex-col gap-6 overflow-y-auto max-h-[55vh] md:max-h-[500px] scrollbar-thin text-left pr-2">
          <!-- Achievements Section -->
          <div class="space-y-3">
            <h3 class="text-xs text-cyan-400 font-mono tracking-widest uppercase border-b border-white/5 pb-2">[ UNLOCKED ACHIEVEMENTS ]</h3>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3" id="achievements-container">
              <!-- Dynamically populated via JS -->
            </div>
          </div>

          <!-- Galactic Inventory Section -->
          <div class="space-y-3">
            <h3 class="text-xs text-cyan-400 font-mono tracking-widest uppercase border-b border-white/5 pb-2">[ GALACTIC INVENTORY ]</h3>
            <div class="grid grid-cols-2 sm:grid-cols-3 gap-3" id="inventory-container">
              <!-- Dynamically populated via JS -->
            </div>
          </div>
        </div>
      </div>
    </main>

    <!-- Footer -->
    <footer class="w-full max-w-7xl mx-auto flex justify-between items-center z-10 font-mono text-[9px] text-slate-600">
      <span>&copy; 2026 COSMICRAFTS. PROFILE HUB V1.0</span>
      <span>SECURE ENCRYPTED CONNECTION</span>
    </footer>
  </div>
</Layout>

<script>
