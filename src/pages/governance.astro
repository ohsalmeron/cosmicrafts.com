      quality: "great",
      votesFor: 48900000,
      votesAgainst: 47100000,
      status: "active",
      author: "bizkit_0x1337",
      gitops: true
    },
    {
      id: "CC-PROP-004",
      title: "Change default player spaceship horn sound to a literal 'Bruh' sound effect",
      description: "Change the audio file for the multiplayer ship horn to the viral 'Bruh' sound effect. This is intended to increase player retention and social sharing via standard internet meme culture.",
      category: "GAMEPLAY",
      quality: "meh",
      votesFor: 25000000,
