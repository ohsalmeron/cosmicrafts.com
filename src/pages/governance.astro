---
import Layout from '../layouts/Layout.astro';
import Starfield from '../components/Starfield.astro';
import Header from '../components/Header.astro';
---

<Layout title="Cosmicrafts | GitOps DAO Terminal">
  <div class="fixed inset-0 h-screen w-screen overflow-hidden flex flex-col justify-between p-4 md:p-6 select-none z-10">
    <Starfield />

    <!-- Header component -->
    <Header />

    <!-- Main governance interface -->
    <main class="w-full max-w-7xl mx-auto flex-1 flex flex-col lg:flex-row gap-4 md:gap-6 my-2 overflow-hidden z-10 items-stretch justify-center py-2 h-[calc(100vh-140px)]">
      
      <!-- Left Panel: Proposal Directory -->
      <div class="w-full lg:w-[450px] backdrop-blur-lg bg-slate-950/40 border border-cyan-500/10 rounded-xl p-4 shadow-[0_0_50px_rgba(6,182,212,0.03)] flex flex-col relative justify-between overflow-hidden h-full">
        <!-- Cyber Brackets -->
        <div class="absolute top-0 left-0 w-4 h-4 border-t border-l border-cyan-400/40"></div>
        <div class="absolute top-0 right-0 w-4 h-4 border-t border-r border-cyan-400/40"></div>
        <div class="absolute bottom-0 left-0 w-4 h-4 border-b border-l border-cyan-400/40"></div>
        <div class="absolute bottom-0 right-0 w-4 h-4 border-b border-r border-cyan-400/40"></div>

        <div class="flex flex-col h-full overflow-hidden">
          <!-- Terminal Header -->
          <div class="flex items-center justify-between text-[10px] text-cyan-400 font-mono tracking-widest uppercase mb-3 border-b border-white/5 pb-2">
            <span>[ Proposal Directory ]</span>
            <span id="active-proposal-count">36 Proposals</span>
          </div>

          <!-- Search & Status Filters -->
          <div class="space-y-2 mb-3">
            <input 
              type="text" 
              id="search-input" 
              placeholder="Search by ID, keyword, or author..." 
              class="w-full bg-slate-900/50 border border-white/10 rounded-lg px-3 py-1.5 text-xs text-white placeholder-slate-500 focus:outline-none focus:border-cyan-500/50 transition-colors font-mono"
            />
            
            <!-- Tab Controls -->
            <div class="grid grid-cols-4 gap-1 p-0.5 bg-slate-950/60 border border-white/5 rounded-lg text-[9px] font-mono">
              <button id="tab-active" class="py-1 rounded bg-cyan-500/15 border border-cyan-500/20 text-cyan-300 uppercase tracking-wider tab-btn">CURRENT</button>
              <button id="tab-passed" class="py-1 rounded text-slate-400 hover:text-white uppercase tracking-wider tab-btn font-mono">PASSED</button>
              <button id="tab-defeated" class="py-1 rounded text-slate-400 hover:text-white uppercase tracking-wider tab-btn font-mono">DEFEATED</button>
              <button id="tab-all" class="py-1 rounded text-slate-400 hover:text-white uppercase tracking-wider tab-btn font-mono">ALL</button>
            </div>

            <!-- Quality Filter Chips -->
            <div class="flex flex-wrap gap-1 pt-1" id="quality-filters">
              <span class="text-[8px] text-slate-500 font-mono flex items-center mr-1 uppercase">QUALITY:</span>
              <button data-quality="all" class="px-2 py-0.5 rounded border border-cyan-500/30 bg-cyan-500/10 text-cyan-300 text-[8px] font-mono uppercase tracking-wider quality-btn">ALL</button>
              <button data-quality="great" class="px-2 py-0.5 rounded border border-emerald-500/10 bg-white/5 text-emerald-400 text-[8px] font-mono uppercase tracking-wider quality-btn">GREAT</button>
              <button data-quality="good" class="px-2 py-0.5 rounded border border-teal-500/10 bg-white/5 text-teal-400 text-[8px] font-mono uppercase tracking-wider quality-btn">GOOD</button>
              <button data-quality="meh" class="px-2 py-0.5 rounded border-slate-500/10 bg-white/5 text-slate-400 text-[8px] font-mono uppercase tracking-wider quality-btn">MEH</button>
              <button data-quality="bad" class="px-2 py-0.5 rounded border-orange-500/10 bg-white/5 text-orange-400 text-[8px] font-mono uppercase tracking-wider quality-btn">BAD</button>
              <button data-quality="dogshit" class="px-2 py-0.5 rounded border-yellow-500/10 bg-white/5 text-yellow-400 text-[8px] font-mono uppercase tracking-wider quality-btn">DOGSHIT ☣</button>
            </div>
          </div>

          <!-- Scrollable Proposal List -->
          <div id="proposals-list" class="flex-1 overflow-y-auto space-y-2 pr-1 custom-scrollbar">
            <!-- Loading placeholder -->
            <div class="text-center py-10 text-slate-500 font-mono text-xs">Initializing Secure Index...</div>
          </div>
        </div>
      </div>

      <!-- Right Panel: Terminal Workspace -->
      <div class="flex-1 backdrop-blur-lg bg-slate-950/40 border border-cyan-500/10 rounded-xl p-6 shadow-[0_0_50px_rgba(6,182,212,0.03)] flex flex-col relative justify-between overflow-hidden h-full">
        <!-- Cyber Brackets -->
        <div class="absolute top-0 left-0 w-4 h-4 border-t border-l border-cyan-400/40"></div>
        <div class="absolute top-0 right-0 w-4 h-4 border-t border-r border-cyan-400/40"></div>
        <div class="absolute bottom-0 left-0 w-4 h-4 border-b border-l border-cyan-400/40"></div>
        <div class="absolute bottom-0 right-0 w-4 h-4 border-b border-r border-cyan-400/40"></div>

        <!-- Selected Proposal Workspace -->
        <div class="flex flex-col h-full justify-between" id="proposal-detail-workspace">
          <!-- Non-selected placeholder state -->
          <div id="no-selection" class="hidden flex-1 flex-col items-center justify-center text-center font-mono space-y-4">
            <svg class="w-12 h-12 text-cyan-500/30 animate-pulse" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
            <p class="text-xs text-slate-400 uppercase tracking-widest">[ SELECT A PROPOSAL FROM DIRECTORY TO MOUNT WORKSPACE ]</p>
          </div>

          <!-- Active Selection Content -->
          <div id="active-selection" class="flex flex-col h-full justify-between gap-4 overflow-hidden workspace-transition">
            <!-- Proposal Info Section -->
            <div class="space-y-4 overflow-y-auto pr-1 max-h-[50%] custom-scrollbar">
              <div class="flex items-center justify-between text-[10px] text-cyan-400 font-mono tracking-widest uppercase border-b border-white/5 pb-2">
                <span id="detail-id">CC-PROP-001</span>
                <span id="detail-quality-pill" class="px-2 py-0.5 rounded bg-cyan-500/10 border border-cyan-500/20 text-cyan-300 text-[8px]">EXCELLENT</span>
              </div>

              <div class="space-y-2">
                <h1 id="detail-title" class="text-xl font-black text-white uppercase tracking-tight leading-tight">INITIALIZING SECURE INDEX...</h1>
                <div class="flex items-center gap-4 text-[10px] font-mono text-slate-500">
                  <span>PROPOSER: <span id="detail-author" class="text-white">FOUNDER_0X</span></span>
                  <span>CATEGORY: <span id="detail-category" class="text-cyan-400">INFRASTRUCTURE</span></span>
                  <span>STATUS: <span id="detail-status" class="text-emerald-400 uppercase">ACTIVE</span></span>
                </div>
              </div>

              <div class="bg-white/5 p-4 rounded-lg border border-white/5">
                <p id="detail-description" class="text-xs text-slate-300 font-light leading-relaxed select-text">
                  Loading secure proposal metadata. Please stand by...
                </p>
              </div>
            </div>

            <!-- Voting Matrix Panel -->
            <div class="bg-slate-950/80 border border-white/5 p-4 rounded-xl space-y-4 font-mono">
              <div class="flex justify-between items-center text-[10px] text-slate-500">
                <span>VOTE SPECTRUM SUMMARY</span>
                <span class="text-slate-400" id="total-voted-count">TOTAL: 87,300,000 SPIRAL</span>
              </div>

              <!-- Vote Bar -->
              <div class="space-y-2">
                <div class="h-3 w-full bg-slate-900 rounded-full overflow-hidden flex border border-white/5 relative">
                  <div id="vote-bar-for" class="h-full bg-emerald-500/30 border-r border-emerald-400 transition-all duration-700 ease-out" style="width: 52%"></div>
                  <div id="vote-bar-against" class="h-full bg-rose-500/30 transition-all duration-700 ease-out" style="width: 48%"></div>
                </div>
                <div class="flex justify-between text-[10px]">
                  <span class="text-emerald-400 flex items-center gap-1.5">
                    <span class="inline-block w-1.5 h-1.5 rounded-full bg-emerald-400"></span>
                    FOR: <span id="detail-votes-for-pct">52%</span> (<span id="detail-votes-for-abs">45M</span>)
                  </span>
                  <span class="text-rose-400 flex items-center gap-1.5 justify-end">
                    AGAINST: <span id="detail-votes-against-pct">48%</span> (<span id="detail-votes-against-abs">42M</span>)
                    <span class="inline-block w-1.5 h-1.5 rounded-full bg-rose-400"></span>
                  </span>
                </div>
              </div>

              <!-- Vote Console (Interactive Area) -->
              <div id="voting-console" class="space-y-3 pt-2 border-t border-white/5">
                <div class="flex items-center justify-between text-[10px]">
                  <span class="text-slate-500">YOUR VOTING ACCOUNT:</span>
                  <span id="user-status-info" class="text-emerald-400">CONNECTED (70,000,000 SPIRAL)</span>
                </div>

                <!-- Alert of Swing Potential -->
                <div id="swing-banner" class="bg-cyan-500/5 border border-cyan-500/20 px-3 py-2 rounded-lg flex items-center justify-between text-[10px] animate-pulse">
                  <span class="text-cyan-400 uppercase tracking-widest flex items-center gap-1.5">
                    <span class="inline-block w-1.5 h-1.5 rounded bg-cyan-400"></span>
                    Tide Turner Mode Active
                  </span>
                  <span class="text-slate-400">YOUR 70M VOTE SWINGS THE DECISION!</span>
                </div>

                <div class="grid grid-cols-2 gap-3" id="vote-btn-grid">
                  <button id="btn-vote-for" class="py-3 bg-emerald-500/10 border border-emerald-500/25 hover:bg-emerald-500/20 text-emerald-400 font-mono text-xs tracking-widest uppercase rounded-lg transition-all duration-300 hover:border-emerald-400">
                    Vote For (Approve)
                  </button>
                  <button id="btn-vote-against" class="py-3 bg-rose-500/10 border border-rose-500/25 hover:bg-rose-500/20 text-rose-400 font-mono text-xs tracking-widest uppercase rounded-lg transition-all duration-300 hover:border-rose-400">
                    Vote Against (Reject)
                  </button>
                </div>

                <!-- Connect Wallet fallback -->
                <div id="login-fallback" class="hidden text-center p-2 bg-white/5 border border-white/5 rounded-lg">
                  <p class="text-[10px] text-slate-400 uppercase mb-2">Connect wallet to enable voting power</p>
                  <button id="btn-fallback-connect" class="px-4 py-1.5 bg-cyan-500/20 hover:bg-cyan-500/35 text-cyan-300 text-[9px] uppercase tracking-wider rounded border border-cyan-500/30 font-bold transition-all duration-300">
                    Connect Wallet
                  </button>
                </div>
              </div>

              <!-- Immutable Consensus Terminal -->
              <div class="border-t border-white/5 pt-3">
                <div class="flex items-center justify-between text-[8px] text-slate-500 mb-1">
                  <span>ETHEREUM MULTI-PROVIDER VALIDATION (4 NODES)</span>
                  <span class="text-emerald-400 flex items-center gap-1">
                    <span class="w-1 h-1 bg-emerald-400 rounded-full animate-pulse"></span>
                    SYNCED
                  </span>
                </div>
                <div class="grid grid-cols-4 gap-1 text-[8px] text-center font-mono">
                  <div id="node-alchemy" class="py-1 bg-slate-900 border border-emerald-500/20 text-emerald-400 rounded">ALCHEMY // SECURE</div>
                  <div id="node-infura" class="py-1 bg-slate-900 border border-emerald-500/20 text-emerald-400 rounded">INFURA // SECURE</div>
                  <div id="node-quicknode" class="py-1 bg-slate-900 border border-emerald-500/20 text-emerald-400 rounded">QUICKNODE // SECURE</div>
                  <div id="node-ankr" class="py-1 bg-slate-900 border border-emerald-500/20 text-emerald-400 rounded">ANKR // SECURE</div>
                </div>
              </div>

              <!-- Simulated vote action feedback -->
              <div id="vote-success-terminal" class="hidden text-left bg-slate-900/80 border border-cyan-500/30 p-3 rounded-lg font-mono text-[9px] text-slate-400 space-y-1 overflow-hidden max-h-28 overflow-y-auto">
                <div class="text-emerald-400 font-bold uppercase tracking-wider text-[10px] mb-1">✓ DECIDING VOTE BROADCASTED SUCCESSFULLY</div>
                <div>[0.00s] Initiating Web3 wallet signing sequence...</div>
                <div>[0.45s] Signature authenticated via Ethereum RPC block #1948271.</div>
                <div>[0.90s] Injected 70,000,000 SPIRAL voting weight.</div>
                <div class="text-cyan-400">[1.35s] Swung proposal result. Syncing with GitHub webhooks...</div>
                <div class="text-emerald-400" id="github-gitops-log">[1.80s] GitHub Action triggered. PR auto-merging verified.</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </main>

    <!-- Footer -->
    <footer class="w-full max-w-7xl mx-auto flex justify-between items-center z-10 font-mono text-[9px] text-slate-600 mt-1">
      <span>&copy; 2026 COSMICRAFTS. GITOPS DAO TERMINAL V0.2</span>
      <span>ETHEREUM MULTI-SIG INTEGRATION (4 RPC NODES CONSENSUS)</span>
    </footer>

    <!-- Spectacular Vote Impact Overlay -->
    <div id="vote-impact-overlay" class="fixed inset-0 z-[10000] hidden items-center justify-center bg-black/60 backdrop-blur-md select-none font-mono">
      
      <!-- Central glass card -->
      <div id="impact-card" class="relative w-full max-w-2xl mx-4 bg-slate-950/85 border border-emerald-500/20 rounded-2xl p-6 md:p-10 shadow-[0_0_80px_rgba(16,185,129,0.15)] text-center space-y-6 overflow-hidden transform scale-95 opacity-0 transition-all duration-500">
        <!-- Corner Brackets -->
        <div id="impact-bracket-tl" class="absolute top-0 left-0 w-8 h-8 border-t-2 border-l-2 border-emerald-400"></div>
        <div id="impact-bracket-tr" class="absolute top-0 right-0 w-8 h-8 border-t-2 border-r-2 border-emerald-400"></div>
        <div id="impact-bracket-bl" class="absolute bottom-0 left-0 w-8 h-8 border-b-2 border-l-2 border-emerald-400"></div>
        <div id="impact-bracket-br" class="absolute bottom-0 right-0 w-8 h-8 border-b-2 border-r-2 border-emerald-400"></div>
        
        <!-- Blinking Warning indicator -->
        <div class="text-[9px] md:text-[10px] text-slate-500 uppercase tracking-[0.3em] font-bold flex items-center justify-center gap-2">
          <span class="inline-block w-2.5 h-2.5 rounded-full bg-emerald-500 animate-pulse" id="impact-ping"></span>
          [ GITOPS_CONSENSUS_ENGINE_RUNNING ]
        </div>

        <div class="space-y-2">
          <h2 id="impact-status-header" class="text-3xl md:text-5xl font-black tracking-wider text-emerald-400 uppercase select-text">PROPOSAL APPROVED</h2>
          <p id="impact-proposal-id" class="text-xs text-slate-400 font-bold uppercase tracking-widest select-text">[ CC-PROP-001 ]</p>
        </div>

        <!-- Progress visual slider -->
        <div class="space-y-1 max-w-md mx-auto">
          <div class="flex justify-between text-[8px] md:text-[9px] text-slate-500">
            <span>SEQUENCE STAGE</span>
            <span id="sequence-stage-percent">0%</span>
          </div>
          <div class="h-1.5 w-full bg-slate-900 border border-white/5 rounded-full overflow-hidden">
            <div id="impact-progress-bar" class="h-full bg-emerald-500 w-0 transition-all duration-300 ease-out shadow-[0_0_10px_rgba(16,185,129,0.5)]"></div>
          </div>
        </div>

        <!-- Terminal Logs Scrolling -->
        <div class="bg-black/80 border border-white/5 p-4 rounded-lg font-mono text-[10px] md:text-xs text-left text-slate-400 space-y-1.5 h-36 overflow-y-auto custom-scrollbar" id="impact-logs-container">
          <!-- Dynamically populated via JS typing effect -->
        </div>

        <!-- Bottom Warning -->
        <div id="impact-action-banner" class="text-[10px] text-emerald-400 uppercase tracking-widest bg-emerald-500/10 border border-emerald-500/20 py-2 rounded-lg font-bold">
          PR AUTO-MERGE TRIGGERED // ETHEREUM LEDGER FINALIZED
        </div>
      </div>
    </div>
  </div>
</Layout>

<style>
  /* Custom Scrollbar */
  .custom-scrollbar::-webkit-scrollbar {
    width: 4px;
  }
  .custom-scrollbar::-webkit-scrollbar-track {
    background: rgba(255, 255, 255, 0.02);
    border-radius: 2px;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb {
    background: rgba(6, 182, 212, 0.15);
    border-radius: 2px;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb:hover {
    background: rgba(6, 182, 212, 0.4);
  }

  /* Scanline CRT animation */
  @keyframes scanline {
    0% {
      background-position: 0 0;
    }
    100% {
      background-position: 0 100%;
    }
  }
  .animate-scanline {
    animation: scanline 10s linear infinite;
  }

  /* Slide out transition for removed sidebar items */
  .proposal-slide-out {
    transition: all 0.6s cubic-bezier(0.4, 0, 0.2, 1) !important;
    opacity: 0 !important;
    transform: translateX(-100%) !important;
    height: 0 !important;
    padding-top: 0 !important;
    padding-bottom: 0 !important;
    margin-top: 0 !important;
    margin-bottom: 0 !important;
    overflow: hidden !important;
    border-color: transparent !important;
  }

  /* Transition for workspace detail workspace card */
  .workspace-transition {
    transition: transform 0.5s cubic-bezier(0.25, 1, 0.5, 1), opacity 0.4s ease-out;
  }
  .workspace-hidden {
    opacity: 0 !important;
    transform: translateX(40px) scale(0.97) !important;
    pointer-events: none;
  }
</style>

<script>
  // 36 proposals array database (all states, qualities, issues, and ideas)
  const BASE_PROPOSALS = [
    {
      id: "CC-PROP-001",
      title: "Deploy Base ERC-20 SpiralToken.sol to Ethereum Mainnet",
