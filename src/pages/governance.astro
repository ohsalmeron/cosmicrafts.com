---
import Layout from '../layouts/Layout.astro';
import Starfield from '../components/Starfield.astro';
---

<Layout title="Cosmicrafts | DAO Governance">
  <div class="fixed inset-0 h-screen w-screen overflow-hidden flex flex-col justify-between p-6 md:p-10 select-none z-10">
    <Starfield />

    <!-- Ambient glows -->
    <div class="absolute bottom-1/4 right-1/3 w-[450px] h-[450px] bg-indigo-500/5 rounded-full blur-[120px] pointer-events-none z-0"></div>

    <!-- Header -->
    <header class="w-full max-w-7xl mx-auto flex justify-between items-center z-10">
      <a href="/" class="flex items-center space-x-2">
        <img src="/logo.svg" alt="Cosmicrafts Logo" class="h-6 md:h-8 opacity-95" />
      </a>
      <a href="/" class="text-xs text-slate-400 hover:text-cyan-400 font-mono tracking-widest uppercase transition-all duration-300">
        ← Exit
      </a>
    </header>

    <!-- Main governance interface -->
    <main class="w-full max-w-7xl mx-auto flex-1 flex flex-col md:flex-row gap-6 md:gap-10 my-4 overflow-hidden z-10 items-stretch justify-center py-4">
      
      <!-- Left: Active Proposals -->
      <div class="flex-1 max-w-xl backdrop-blur-lg bg-slate-950/40 border border-cyan-500/10 rounded-xl p-6 shadow-[0_0_50px_rgba(6,182,212,0.05)] overflow-hidden flex flex-col relative justify-between">
        <div class="absolute top-0 left-0 w-4 h-4 border-t border-l border-cyan-400/40"></div>
        <div class="absolute top-0 right-0 w-4 h-4 border-t border-r border-cyan-400/40"></div>
        <div class="absolute bottom-0 left-0 w-4 h-4 border-b border-l border-cyan-400/40"></div>
        <div class="absolute bottom-0 right-0 w-4 h-4 border-b border-r border-cyan-400/40"></div>

        <div>
          <div class="flex items-center justify-between text-[10px] text-cyan-400 font-mono tracking-widest uppercase mb-4 border-b border-white/5 pb-2">
            <span>[ Active Proposals ]</span>
            <span>2 Proposals</span>
          </div>

          <div class="space-y-4 overflow-y-auto max-h-[50vh] pr-2">
            <!-- Proposal 1 -->
            <div class="bg-white/5 border border-white/5 p-4 rounded-lg space-y-2 text-left hover:border-cyan-500/30 transition-all duration-300 cursor-pointer">
              <div class="flex justify-between items-center text-[9px] font-mono">
                <span class="text-cyan-400">PROP #042 // GITOPS_MERGE</span>
                <span class="px-2 py-0.5 rounded bg-amber-500/10 border border-amber-500/20 text-amber-400 uppercase tracking-widest">voting</span>
              </div>
              <p class="text-sm font-bold text-white uppercase tracking-tight">Merge staging to master (v0.8.2)</p>
              <p class="text-xs text-slate-400 font-light leading-relaxed">
                Approve code changes under PR #114 to merge staging into the master deployment branch.
              </p>
              <div class="flex justify-between items-center font-mono text-[9px] text-slate-500 pt-2 border-t border-white/5">
                <span>VOTES: 42,102,000 SPIRAL</span>
                <span class="text-cyan-400">END_TIME: 12H</span>
              </div>
            </div>

            <!-- Proposal 2 -->
            <div class="bg-white/5 border border-white/5 p-4 rounded-lg space-y-2 text-left opacity-60 hover:opacity-100 transition-all duration-300 cursor-pointer">
              <div class="flex justify-between items-center text-[9px] font-mono">
                <span class="text-slate-500">PROP #041 // TREASURY_RELEASE</span>
                <span class="px-2 py-0.5 rounded bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 uppercase tracking-widest">passed</span>
              </div>
              <p class="text-sm font-bold text-white uppercase tracking-tight">Transfer 20,000 SPIRAL for Server Scaling</p>
              <p class="text-xs text-slate-400 font-light leading-relaxed">
                Release tokens from the Gnosis Safe treasury to cover Q3 cloud multiplayer server costs.
              </p>
              <div class="flex justify-between items-center font-mono text-[9px] text-slate-500 pt-2 border-t border-white/5">
                <span>VOTES: 98,124,000 SPIRAL</span>
                <span class="text-emerald-400">MERGED VIA GITHUB ACTION</span>
              </div>
            </div>
          </div>
        </div>

        <div class="border-t border-white/5 pt-4 mt-4 text-center">
          <p class="text-[10px] text-slate-500 font-mono">VOTING STAKE CONVERTS HELD TOKENS INTO VOTING POWER</p>
        </div>
      </div>

      <!-- Right: Voting Console -->
      <div class="w-full md:w-80 backdrop-blur-lg bg-slate-950/40 border border-cyan-500/10 rounded-xl p-6 shadow-[0_0_50px_rgba(6,182,212,0.05)] overflow-hidden flex flex-col justify-between relative">
        <div class="absolute top-0 left-0 w-4 h-4 border-t border-l border-cyan-400/40"></div>
        <div class="absolute top-0 right-0 w-4 h-4 border-t border-r border-cyan-400/40"></div>
        <div class="absolute bottom-0 left-0 w-4 h-4 border-b border-l border-cyan-400/40"></div>
        <div class="absolute bottom-0 right-0 w-4 h-4 border-b border-r border-cyan-400/40"></div>

        <div>
          <div class="flex items-center justify-between text-[10px] text-cyan-400 font-mono tracking-widest uppercase mb-4 border-b border-white/5 pb-2">
            <span>[ Vote Terminal ]</span>
            <span>PROP #042</span>
          </div>

          <div class="space-y-4 font-mono text-xs">
            <div class="bg-white/5 border border-white/5 p-4 rounded-lg space-y-2 text-left">
              <div class="flex justify-between text-[10px] text-slate-500">
                <span>YOUR VOTING POWER:</span>
                <span class="text-cyan-400">70,000,000 SPIRAL</span>
              </div>
              <div class="flex justify-between text-[10px] text-slate-500">
                <span>STAKING STATUS:</span>
                <span class="text-emerald-400">LOCKED (FOUNDER)</span>
              </div>
            </div>

            <!-- Cast Votes -->
            <div class="space-y-2 pt-2">
              <button id="btn-approve" class="w-full py-3 bg-emerald-500/20 border border-emerald-500/30 hover:bg-emerald-500/30 text-emerald-400 font-mono text-xs tracking-widest uppercase rounded-lg transition-all duration-300">
                Approve & Merge
              </button>
              <button id="btn-reject" class="w-full py-3 bg-rose-500/20 border border-rose-500/30 hover:bg-rose-500/30 text-rose-400 font-mono text-xs tracking-widest uppercase rounded-lg transition-all duration-300">
                Reject & Close
              </button>
            </div>
          </div>
        </div>

        <!-- Simulated voting action feedback -->
        <div id="vote-feedback" class="hidden text-center space-y-2 font-mono border-t border-white/5 pt-4">
          <span class="text-[10px] text-emerald-400 uppercase tracking-widest block">✓ Vote cast successfully</span>
          <p class="text-[9px] text-slate-500 leading-relaxed">
            GitHub API webhook received. Auto-merging PR #114 when vote cycle completes.
          </p>
        </div>
      </div>
    </main>

    <!-- Footer -->
    <footer class="w-full max-w-7xl mx-auto flex justify-between items-center z-10 font-mono text-[9px] text-slate-600">
      <span>&copy; 2026 COSMICRAFTS. GITOPS DAO TERMINAL V0.1</span>
      <span>ETHEREUM MULTI-SIG INTEGRATION</span>
    </footer>
  </div>
</Layout>

<script>
  const btnApprove = document.getElementById('btn-approve');
  const btnReject = document.getElementById('btn-reject');
  const voteFeedback = document.getElementById('vote-feedback');

  btnApprove?.addEventListener('click', () => {
    btnApprove.innerText = "Voting...";
    btnApprove.setAttribute('disabled', 'true');
    if (btnReject) btnReject.style.display = 'none';
    
    setTimeout(() => {
      btnApprove.innerText = "APPROVED";
      btnApprove.classList.add('bg-emerald-500/40');
      voteFeedback?.classList.remove('hidden');
    }, 1200);
  });
</script>
