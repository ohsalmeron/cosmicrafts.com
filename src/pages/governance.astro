          <div>[0.00s] Connected via MetaMask address: 0x71C...9312</div>
          <div>[0.35s] Signature authenticated via Ethereum multi-sig block.</div>
          <div>[0.70s] Registered voting weight: ${userVotingPower.toLocaleString()} SPIRAL (Locked Vesting).</div>
          <div class="text-cyan-400">[1.10s] Current vote outcome: ${castVote === 'for' ? 'PASSED & APPROVED' : 'REJECTED & DEFEATED'}</div>
          <div class="${prop.gitops ? 'text-emerald-400' : 'text-teal-400'} font-mono">[1.55s] Consensus: ${prop.gitops ? '✓ GitHub Webhook triggered. Auto-merging verified.' : '✓ Transaction ledger state saved.'}</div>
        `;
      } else {
        // Can vote! Show Tide Turner Swing Indicator
        voteBtnGrid?.classList.remove('hidden');
        swingBanner?.classList.remove('hidden');
        voteSuccessTerminal?.classList.add('hidden');

        // Reset button states so the next active proposal is completely interactable
        if (btnVoteFor) {
          btnVoteFor.removeAttribute('disabled');
          btnVoteFor.innerText = "Vote For (Approve)";
          btnVoteFor.style.opacity = "1";
        }
        if (btnVoteAgainst) {
          btnVoteAgainst.removeAttribute('disabled');
          btnVoteAgainst.innerText = "Vote Against (Reject)";
          btnVoteAgainst.style.opacity = "1";
        }

        // Calculate swing
        const diff = Math.abs(prop.votesFor - prop.votesAgainst);
        const diffFormatted = formatCompact(diff);
        swingBanner.innerHTML = `
          <span class="text-cyan-400 uppercase tracking-widest flex items-center gap-1.5">
            <span class="inline-block w-1.5 h-1.5 rounded bg-cyan-400 animate-ping"></span>
            Tide Turner Mode Active
          </span>
          <span class="text-slate-300">DIFF IS ONLY ${diffFormatted}. YOUR 70M SPIRAL SWINGS THE OUTCOME!</span>
        `;
      }
    }

    // Update node simulation (simulate latency for verification consensus)
    triggerNodeValidationAnimation();
  };

  // Simulated node validation animations
  const triggerNodeValidationAnimation = () => {
    const rpcs = [nodes.alchemy, nodes.infura, nodes.quicknode, nodes.ankr];
    rpcs.forEach((node, i) => {
      if (!node) return;
      node.className = "py-1 bg-slate-900 border border-cyan-500/10 text-slate-500 rounded animate-pulse";
      node.innerText = "VERIFYING...";
      
      setTimeout(() => {
        node.className = "py-1 bg-slate-900 border border-emerald-500/20 text-emerald-400 rounded transition-all duration-300";
        node.innerText = `${node.id.split('-')[1].toUpperCase()} // SECURE`;
      }, 400 + i * 150);
    });
  };

  // Spectacular Vote Impact Overlay sequence
  const showDramaticImpact = (direction, prop) => {
    if (!voteImpactOverlay || !impactCard || !impactLogsContainer || !impactProgressBar || !sequenceStagePercent || !impactStatusHeader || !impactActionBanner || !impactPing) return;

    // Clear previous logs
    impactLogsContainer.innerHTML = '';
    impactProgressBar.style.width = '0%';
    sequenceStagePercent.innerText = '0%';

    // Set layout based on vote direction (Approved vs Rejected)
    const isApproved = direction === 'for';
    
    // Reset any direction-specific colors first
    impactCard.className = "relative w-full max-w-2xl mx-4 bg-slate-950/85 border rounded-2xl p-6 md:p-10 text-center space-y-6 overflow-hidden transform scale-95 opacity-0 transition-all duration-500";
    
    if (isApproved) {
      // PROPOSAL APPROVED (Emerald / Cyan)
      impactCard.classList.add('border-emerald-500/30', 'shadow-[0_0_80px_rgba(16,185,129,0.25)]');
      impactStatusHeader.className = "text-2xl md:text-4xl font-black tracking-wider text-emerald-400 uppercase animate-pulse select-text";
      impactStatusHeader.innerText = "PROPOSAL APPROVED // MERGE CODES RUNNING";
      
      impactProgressBar.className = "h-full bg-emerald-500 transition-all duration-300 ease-out shadow-[0_0_10px_rgba(16,185,129,0.5)]";
      sequenceStagePercent.className = "text-emerald-400 font-mono";
      
      impactActionBanner.className = "text-[10px] text-emerald-400 uppercase tracking-widest bg-emerald-500/10 border border-emerald-500/20 py-2 rounded-lg font-bold font-mono";
      impactActionBanner.innerText = "✓ CODE DEPLOYMENT INITIATED // ETHEREUM FINALIZED";
      
      impactPing.className = "inline-block w-2.5 h-2.5 rounded-full bg-emerald-500 animate-ping";
      
      impactBrackets.forEach(b => {
        if (b) b.className = b.className.replace(/border-(rose|emerald|cyan|red)-\d+/g, 'border-emerald-400');
      });
    } else {
      // PROPOSAL DEFEATED / REJECTED (Rose / Red)
      impactCard.classList.add('border-rose-500/40', 'shadow-[0_0_80px_rgba(244,63,94,0.3)]');
      impactStatusHeader.className = "text-2xl md:text-4xl font-black tracking-wider text-rose-500 uppercase select-text";
      impactStatusHeader.innerText = "PROPOSAL REJECTED // PR TERMINATED";
      
      impactProgressBar.className = "h-full bg-rose-500 transition-all duration-300 ease-out shadow-[0_0_10px_rgba(244,63,94,0.5)]";
      sequenceStagePercent.className = "text-rose-400 font-mono";
      
      impactActionBanner.className = "text-[10px] text-rose-400 uppercase tracking-widest bg-rose-500/10 border border-rose-500/20 py-2 rounded-lg font-bold font-mono animate-pulse";
      impactActionBanner.innerText = "☣ PROPOSAL TERMINATED // PULL REQUEST SHUTDOWN";
      
      impactPing.className = "inline-block w-2.5 h-2.5 rounded-full bg-rose-500 animate-ping";
      
      impactBrackets.forEach(b => {
        if (b) b.className = b.className.replace(/border-(rose|emerald|cyan|red)-\d+/g, 'border-rose-500');
      });
    }

    impactProposalId.innerText = `[ ${prop.id} // ${prop.category} ]`;

    // Unhide overlay
    voteImpactOverlay.classList.remove('hidden');
    voteImpactOverlay.classList.add('flex');
    
    // Animate zoom in
    setTimeout(() => {
      impactCard.classList.remove('scale-95', 'opacity-0');
      impactCard.classList.add('scale-100', 'opacity-100');
    }, 50);

    // Logging steps
    const logs = isApproved ? [
      { text: `[SYSTEM] Connection authenticated from address: 0x71C...9312 (Vesting Signature)`, class: "text-slate-500 font-mono" },
      { text: `[STATE] Staked Balance Checked: 70,000,000 SPIRAL parsed.`, class: "text-slate-400 font-mono" },
      { text: `[STATE] INJECTING DECIDING POWER (+70M SPIRAL WEIGHT TO APPROVED)...`, class: "text-emerald-400 font-bold font-mono" },
      { text: `[CONSENSUS] QUORUM STAGE MET: Total Votes passed threshold.`, class: "text-cyan-400 font-mono" },
      { text: `[CONSENSUS] Multi-sig execution contract verified on 4 independent RPC Nodes.`, class: "text-cyan-400 font-mono" },
      { text: `[GITHUB] Dispatching secure GitOps webhook to repo main branch...`, class: "text-slate-400 font-mono" },
      { text: `[GITHUB] Triggering actions runner: merging branch 'staging' into 'master'.`, class: "text-slate-400 font-mono" },
      { text: `[DEPLOY] Auto-deployment running... Static assets compiling...`, class: "text-slate-400 font-mono" },
      { text: `[DEPLOY] GITOPS PR AUTO-MERGED: Status 200 (SUCCESS).`, class: "text-emerald-400 font-bold animate-pulse font-mono" },
      { text: `[SYSTEM] Consensus loop completed. Clearing memory channels...`, class: "text-slate-500 font-mono" }
    ] : [
      { text: `[SYSTEM] Connection authenticated from address: 0x71C...9312 (Vesting Signature)`, class: "text-slate-500 font-mono" },
      { text: `[STATE] Staked Balance Checked: 70,000,000 SPIRAL parsed.`, class: "text-slate-400 font-mono" },
      { text: `[STATE] INJECTING DECIDING POWER (+70M SPIRAL WEIGHT TO REJECTED)...`, class: "text-rose-400 font-bold font-mono" },
      { text: `[CONSENSUS] SHUTDOWN THRESHOLD MET: Defeat weight overrides approval.`, class: "text-red-400 font-mono" },
      { text: `[CONSENSUS] Multi-sig execution sequence ABORTED. Gnosis Safe transaction cancelled.`, class: "text-red-400 font-mono" },
      { text: `[GITHUB] Dispatching rejection webhook to repository controllers...`, class: "text-slate-400 font-mono" },
      { text: `[GITHUB] Triggering actions runner: closing PR #${prop.id.split('-')[2]} without merging.`, class: "text-slate-400 font-mono" },
      { text: `[DEPLOY] GITOPS STATUS: PR CLOSED & ARCHIVED. CODE LOCKED [403]`, class: "text-rose-400 font-bold animate-pulse font-mono" },
      { text: `[SYSTEM] Proposal terminated successfully. All voting power released.`, class: "text-slate-500 font-mono" }
    ];

    let currentLogIndex = 0;
    const totalLogs = logs.length;

    const printNextLog = () => {
      if (currentLogIndex < totalLogs) {
        const log = logs[currentLogIndex];
        const logLine = document.createElement('div');
        logLine.className = `${log.class}`;
        logLine.innerText = `> ${log.text}`;
        impactLogsContainer.appendChild(logLine);
        impactLogsContainer.scrollTop = impactLogsContainer.scrollHeight;

        // Update progress bar
        const pct = Math.round(((currentLogIndex + 1) / totalLogs) * 100);
        impactProgressBar.style.width = `${pct}%`;
        sequenceStagePercent.innerText = `${pct}%`;

        currentLogIndex++;
        setTimeout(printNextLog, 250);
      } else {
        // All logs completed! Wait 1.5s to savor the victory/defeat, then close overlay
        setTimeout(() => {
          // Fade out card
          impactCard.classList.remove('scale-100', 'opacity-100');
          impactCard.classList.add('scale-95', 'opacity-0');
          
          setTimeout(() => {
            // Hide overlay completely
            voteImpactOverlay.classList.remove('flex');
            voteImpactOverlay.classList.add('hidden');
            
            // --- START SMOOTH SWAP SEQUENCE (PAST -> PRESENT) ---
            // 1. Slide out and collapse the old sidebar item
            const sidebarItem = document.querySelector(`[data-id="${prop.id}"]`);
            if (sidebarItem) {
              sidebarItem.classList.add('proposal-slide-out');
            }

            // 2. Slide out and fade the old workspace details
            const activeSelection = document.getElementById('active-selection');
            if (activeSelection) {
              activeSelection.classList.add('workspace-hidden');
            }

            // Wait 600ms for slide-out animations to fully complete
            setTimeout(() => {
              // Find the current filtered list items to determine the next proposal ID
              const query = searchInput.value.toLowerCase();
              const filtered = proposals.filter(p => {
                const matchesSearch = p.id.toLowerCase().includes(query) || 
                                      p.title.toLowerCase().includes(query) || 
                                      p.author.toLowerCase().includes(query) ||
                                      p.description.toLowerCase().includes(query);
                let matchesTab = true;
                if (activeTab === "active") {
                  matchesTab = p.status === "active";
                } else if (activeTab === "passed") {
                  matchesTab = p.status === "passed" || p.status === "executed";
                } else if (activeTab === "defeated") {
                  matchesTab = p.status === "defeated";
                }
                let matchesQuality = activeQuality === "all" || p.quality === activeQuality;
                return matchesSearch && matchesTab && matchesQuality;
              });

              // Select the next proposal ID
              const currentIndex = filtered.findIndex(p => p.id === prop.id);
              let nextId = null;
              if (filtered.length > 1) {
                if (currentIndex !== -1 && currentIndex < filtered.length - 1) {
                  nextId = filtered[currentIndex + 1].id;
                } else {
                  nextId = filtered[0].id;
                }
              }

              if (nextId) {
                currentSelectionId = nextId;
              }

              // Re-render list (old item is removed, list slides up cleanly)
              renderList();
              
              // Load the new proposal details (still hidden)
              renderWorkspace();
              
              // Force CSS reflow and slide in next proposal beautifully
              if (activeSelection) {
                activeSelection.classList.add('workspace-hidden');
                void activeSelection.offsetWidth; // force reflow
                activeSelection.classList.remove('workspace-hidden');
              }
            }, 600);
          }, 400);
        }, 1200);
      }
    };

    // Start logging sequence after card transitions open
    setTimeout(printNextLog, 400);
  };

  // Register Vote Logic
  const castVote = (direction) => {
    const prop = proposals.find(p => p.id === currentSelectionId);
    if (!prop || prop.status !== 'active') return;

    // Persist vote
    localStorage.setItem(`vote_${prop.id}`, direction);
    
    // Inject user voting power
    if (direction === 'for') {
      prop.votesFor += userVotingPower;
    } else {
      prop.votesAgainst += userVotingPower;
    }

    // Your vote ALWAYS decides the final outcome absolutely - no restrictions, absolute decision
    if (direction === 'for') {
      prop.status = "passed";
      if (prop.votesFor <= prop.votesAgainst) {
        prop.votesFor = prop.votesAgainst + Math.round(userVotingPower * 0.4);
      }
    } else {
      prop.status = "defeated";
      if (prop.votesAgainst <= prop.votesFor) {
        prop.votesAgainst = prop.votesFor + Math.round(userVotingPower * 0.4);
      }
    }

    saveProposals();
    
    // Render workspace immediately so progress bar slide and terminal logs print
    renderWorkspace();
    
    // Trigger spectacular full screen diagnostic diagnostic overlay
    showDramaticImpact(direction, prop);
  };

  // Add click listeners to vote buttons
  btnVoteFor?.addEventListener('click', () => {
    btnVoteFor.innerText = "SIGNING TX...";
    btnVoteFor.setAttribute('disabled', 'true');
    if (btnVoteAgainst) btnVoteAgainst.style.opacity = '0.3';

    setTimeout(() => {
      castVote('for');
      btnVoteFor.innerText = "VOTED FOR";
    }, 1000);
  });

  btnVoteAgainst?.addEventListener('click', () => {
    btnVoteAgainst.innerText = "SIGNING TX...";
    btnVoteAgainst.setAttribute('disabled', 'true');
    if (btnVoteFor) btnVoteFor.style.opacity = '0.3';

    setTimeout(() => {
      castVote('against');
      btnVoteAgainst.innerText = "VOTED AGAINST";
    }, 1000);
  });

  // Filter button state handlers
  const tabBtns = document.querySelectorAll('.tab-btn');
  tabBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      tabBtns.forEach(b => {
        b.className = "py-1 rounded text-slate-400 hover:text-white uppercase tracking-wider tab-btn";
      });
      btn.className = "py-1 rounded bg-cyan-500/15 border border-cyan-500/20 text-cyan-300 uppercase tracking-wider tab-btn";
      
      const tabId = btn.id.split('-')[1];
      activeTab = tabId;
      renderList();
    });
  });

  const qualityBtns = document.querySelectorAll('.quality-btn');
  qualityBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      qualityBtns.forEach(b => {
        b.className = b.className.replace('border-cyan-500/30 bg-cyan-500/10 text-cyan-300', 'border-white/5 bg-white/5 text-slate-400');
        // keep quality styles colored natively when unselected except default All
        const quality = b.getAttribute('data-quality');
        if (quality !== 'all' && b !== btn) {
          b.className = b.className.replace('text-emerald-400', 'text-slate-400').replace('text-teal-400', 'text-slate-400').replace('text-orange-400', 'text-slate-400').replace('text-yellow-400', 'text-slate-400');
        }
      });
      
      const q = btn.getAttribute('data-quality') || 'all';
      activeQuality = q;
      
      // Restore appropriate color text
      if (q === 'great') btn.className = btn.className.replace('text-slate-400', 'text-emerald-400');
      if (q === 'good') btn.className = btn.className.replace('text-slate-400', 'text-teal-400');
      if (q === 'meh') btn.className = btn.className.replace('text-slate-400', 'text-slate-400');
      if (q === 'bad') btn.className = btn.className.replace('text-slate-400', 'text-orange-400');
      if (q === 'dogshit') btn.className = btn.className.replace('text-slate-400', 'text-yellow-400');

      btn.className = btn.className.replace('border-white/5 bg-white/5', 'border-cyan-500/30 bg-cyan-500/10 text-cyan-300');
      renderList();
    });
  });

  // Search filter
  searchInput?.addEventListener('input', renderList);

  // Fallback Login Connect Wallet triggering standard Header event
  btnFallbackConnect?.addEventListener('click', () => {
    const mainConnectBtn = document.getElementById('btn-open-login');
    if (mainConnectBtn) {
      mainConnectBtn.click();
    }
  });

  // Watch for connection state
  setInterval(() => {
    const currentLoginState = getIsLoggedIn();
    const loginStateCheck = loginFallback?.classList.contains('hidden');
    // If the displayed login fallback visibility is not aligned with actual state, re-render workspace
    if (currentLoginState === loginStateCheck) {
      // already aligned
    } else {
      renderWorkspace();
    }
  }, 1000);

  // Initial Load
  loadProposals();
  renderList();
  renderWorkspace();
</script>