---
import Layout from '../layouts/Layout.astro';
import Starfield from '../components/Starfield.astro';
import Header from '../components/Header.astro';
import Panel from '../components/Panel.astro';
---

<Layout title="Cosmicrafts | Community Claim">
  <div class="fixed inset-0 h-screen w-screen overflow-hidden flex flex-col justify-between p-6 md:p-10 select-none z-10">
    <Starfield />

    <!-- Header component -->
    <Header />

    <!-- Main claims interface -->
    <main class="w-full max-w-7xl mx-auto flex-1 flex items-center justify-center z-10">
      <Panel class="w-full max-w-md p-8 text-center">

        <h2 class="text-xs text-cyan-400 font-mono tracking-widest uppercase mb-2">[ Community allocation ]</h2>
        <h1 class="text-2xl md:text-3xl font-black tracking-tight uppercase text-white mb-6">Claim Portal</h1>

        <!-- Wallet connection simulator -->
        <div id="wallet-section" class="space-y-6">
          <p class="text-xs text-slate-400 font-light leading-relaxed">
            Connect your Ethereum wallet to check and claim your historical community beta rewards.
          </p>

          <button id="btn-connect" class="w-full py-3 bg-gradient-to-r from-cyan-500 to-indigo-500 hover:from-cyan-400 hover:to-indigo-400 text-white font-mono text-xs tracking-widest uppercase rounded-lg shadow-[0_0_20px_rgba(6,182,212,0.2)] transition-all duration-300 transform active:scale-95">
            Connect Wallet
          </button>
        </div>

        <!-- Allocation claim screen (initially hidden) -->
        <div id="claim-section" class="hidden space-y-6">
          <div class="bg-white/5 border border-white/5 p-4 rounded-lg font-mono text-left space-y-2">
            <div class="flex justify-between text-[10px] text-slate-500">
              <span>ADDRESS:</span>
              <span class="text-cyan-400">0x71C...9312</span>
            </div>
            <div class="flex justify-between text-[10px] text-slate-500">
              <span>ELIGIBILITY:</span>
              <span class="text-emerald-400">QUALIFIED</span>
            </div>
            <div class="flex justify-between text-xs text-slate-300 border-t border-white/5 pt-2 mt-2">
              <span>REWARDS BALANCE:</span>
              <span class="text-white font-bold">12,500 SPIRAL</span>
            </div>
          </div>

          <button id="btn-claim" class="w-full py-3 bg-emerald-500 hover:bg-emerald-400 text-white font-mono text-xs tracking-widest uppercase rounded-lg shadow-[0_0_20px_rgba(16,185,129,0.2)] transition-all duration-300 transform active:scale-95">
            Claim Rewards
          </button>
        </div>

        <!-- Success Screen (initially hidden) -->
        <div id="success-section" class="hidden space-y-4 font-mono">
          <div class="w-12 h-12 rounded-full border border-emerald-500 bg-emerald-500/10 flex items-center justify-center mx-auto text-emerald-400 animate-pulse">
            ✓
          </div>
          <p class="text-sm text-white uppercase font-bold">Claim Request Submitted</p>
          <p class="text-[10px] text-slate-400 leading-relaxed">
            Transaction is being processed by the Ethereum ledger. Please monitor your 0x wallet address.
          </p>
          <div class="text-[9px] text-slate-500 border border-white/5 p-2 rounded bg-black/20">
            TX_HASH: 0x9e12...b4fa
          </div>
          </div>
        </Panel>
      </main>

    <!-- Footer -->
    <footer class="w-full max-w-7xl mx-auto flex justify-between items-center z-10 font-mono text-[9px] text-slate-600">
      <a href="https://worldofunreal.com/" target="_blank" class="hover:text-cyan-400 transition-colors uppercase">&copy; 2026 WORLD OF UNREAL. CLAIM MODULE V0.1</a>
      <span>ETHEREUM MAINNET</span>
    </footer>
  </div>
</Layout>

<script>
  // Simple simulator script
  const btnConnect = document.getElementById('btn-connect');
  const btnClaim = document.getElementById('btn-claim');
  const walletSection = document.getElementById('wallet-section');
  const claimSection = document.getElementById('claim-section');
  const successSection = document.getElementById('success-section');

  btnConnect?.addEventListener('click', () => {
    btnConnect.innerText = "Connecting...";
    setTimeout(() => {
      walletSection?.classList.add('hidden');
      claimSection?.classList.remove('hidden');
    }, 1200);
  });

  btnClaim?.addEventListener('click', () => {
    btnClaim.innerText = "Processing...";
    btnClaim.setAttribute('disabled', 'true');
    setTimeout(() => {
      claimSection?.classList.add('hidden');
      successSection?.classList.remove('hidden');
    }, 1800);
  });
</script>
