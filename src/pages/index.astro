---
import Layout from '../layouts/Layout.astro';
import Starfield from '../components/Starfield.astro';
import Header from '../components/Header.astro';
---

<Layout title="Cosmicrafts | Under Construction">
  <!-- Main Viewport-Locked Container -->
  <div class="fixed inset-0 h-screen w-screen overflow-hidden flex flex-col justify-between p-6 md:p-10 select-none z-10 bg-[#020208]">
    <!-- Starfield Animated Background -->
    <Starfield />

    <!-- Header component -->
    <Header />

    <!-- Main Dynamic Section -->
    <main class="w-full max-w-7xl mx-auto flex-1 flex items-center justify-center z-10 gap-10 overflow-hidden my-4">
      
      <!-- Center: Text/Glassmorphic Card with grid cards inside -->
      <div class="w-full max-w-2xl flex flex-col justify-center">
        <div class="relative backdrop-blur-lg bg-slate-950/40 border border-cyan-500/10 rounded-xl p-6 md:p-8 shadow-[0_0_50px_rgba(6,182,212,0.05)] overflow-hidden">
          <!-- Cyber Corner Brackets -->
          <div class="absolute top-0 left-0 w-6 h-6 border-t border-l border-cyan-400/60"></div>
          <div class="absolute top-0 right-0 w-6 h-6 border-t border-r border-cyan-400/60"></div>
          <div class="absolute bottom-0 left-0 w-6 h-6 border-b border-l border-cyan-400/60"></div>
          <div class="absolute bottom-0 right-0 w-6 h-6 border-b border-r border-cyan-400/60"></div>

          <!-- Technical Specs Sub-header -->
          <div class="flex items-center justify-between text-[9px] text-cyan-500 font-mono tracking-widest uppercase mb-4 border-b border-white/5 pb-2">
            <span>[ SYSTEM STATUS: REBUILD ]</span>
            <span>COMMUNICATION // DIRECT</span>
          </div>

          <!-- Title -->
          <h1 class="text-3xl md:text-5xl font-black tracking-tight uppercase leading-none mb-3 bg-gradient-to-r from-white via-slate-100 to-cyan-400 bg-clip-text text-transparent">
            THE NEXT CHAPTER
          </h1>

          <!-- Plain English Statement -->
          <p class="text-xs md:text-sm text-slate-300 font-light leading-relaxed mb-6 text-justify">
            We are restructuring the entire Cosmicrafts ecosystem. Real-time gameplay, matchmaking, and player progression run on optimized, high-performance cloud infrastructure for fluid, competitive play. The SPIRAL token will live permanently on Ethereum, while we honor our community legacy by supporting our original ICP NFTs.
          </p>

          <!-- Grid of 3 Interactive Module Cards -->
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 w-full pt-4 border-t border-white/10">
            <!-- Module 1: Claim Portal -->
            <a href="/claim" class="group backdrop-blur-md bg-white/5 border border-white/5 hover:border-cyan-500/30 hover:bg-cyan-950/10 p-3 rounded-lg text-left transition-all duration-300 relative shadow-[0_0_15px_rgba(6,182,212,0.02)]">
              <div class="absolute top-0 right-0 w-2 h-2 border-t border-r border-cyan-500/30 group-hover:border-cyan-400"></div>
              <div class="text-[8px] text-cyan-400 font-mono tracking-widest uppercase mb-0.5">[ MODULE_01 ]</div>
              <div class="text-xs font-bold text-white uppercase tracking-tight group-hover:text-cyan-300">CLAIM PANEL</div>
              <p class="text-[9px] text-slate-400 font-light mt-1 leading-normal">Claim community and beta incentives.</p>
            </a>

            <!-- Module 2: DAO Governance -->
            <a href="/governance" class="group backdrop-blur-md bg-white/5 border border-white/5 hover:border-cyan-500/30 hover:bg-cyan-950/10 p-3 rounded-lg text-left transition-all duration-300 relative shadow-[0_0_15px_rgba(6,182,212,0.02)]">
              <div class="absolute top-0 right-0 w-2 h-2 border-t border-r border-cyan-500/30 group-hover:border-cyan-400"></div>
              <div class="text-[8px] text-cyan-400 font-mono tracking-widest uppercase mb-0.5">[ MODULE_02 ]</div>
              <div class="text-xs font-bold text-white uppercase tracking-tight group-hover:text-cyan-300">DAO GOVERNANCE</div>
              <p class="text-[9px] text-slate-400 font-light mt-1 leading-normal">Vote on code merges & treasury.</p>
            </a>

            <!-- Module 3: Whitepaper -->
            <a href="/docs/introduction" class="group backdrop-blur-md bg-white/5 border border-white/5 hover:border-cyan-500/30 hover:bg-cyan-950/10 p-3 rounded-lg text-left transition-all duration-300 relative shadow-[0_0_15px_rgba(6,182,212,0.02)]">
              <div class="absolute top-0 right-0 w-2 h-2 border-t border-r border-cyan-500/30 group-hover:border-cyan-400"></div>
              <div class="text-[8px] text-cyan-400 font-mono tracking-widest uppercase mb-0.5">[ MODULE_03 ]</div>
              <div class="text-xs font-bold text-white uppercase tracking-tight group-hover:text-cyan-300">WHITEPAPER</div>
              <p class="text-[9px] text-slate-400 font-light mt-1 leading-normal">Read architecture & tokenomics.</p>
            </a>
          </div>
        </div>
      </div>
    </main>

    <!-- Footer -->
    <footer class="w-full max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center z-10 gap-4 border-t border-white/5 pt-4 font-mono text-[9px] md:text-xs text-slate-500">
      <div class="flex items-center space-x-1">
        <span>&copy; 2026 COSMICRAFTS. ALL RIGHTS RESERVED.</span>
      </div>
      
      <!-- Social links with glowing glass circles -->
      <div class="flex items-center space-x-3">
        <a href="https://x.com/cosmicrafts" target="_blank" class="p-2.5 rounded-lg border border-white/10 bg-white/5 hover:bg-cyan-500/15 hover:border-cyan-400/40 hover:shadow-[0_0_15px_rgba(6,182,212,0.25)] transition-all duration-300">
          <img src="/assets/icons/x.svg" alt="X" class="w-4 h-4 md:w-5 md:h-5 opacity-90 hover:opacity-100" />
        </a>
        <a href="https://discord.com/invite/cosmicrafts-884272584491941888" target="_blank" class="p-2.5 rounded-lg border border-white/10 bg-white/5 hover:bg-cyan-500/15 hover:border-cyan-400/40 hover:shadow-[0_0_15px_rgba(6,182,212,0.25)] transition-all duration-300">
          <img src="/assets/icons/discord.svg" alt="Discord" class="w-4 h-4 md:w-5 md:h-5 opacity-90 hover:opacity-100" />
        </a>
        <a href="https://www.youtube.com/@cosmicrafts" target="_blank" class="p-2.5 rounded-lg border border-white/10 bg-white/5 hover:bg-cyan-500/15 hover:border-cyan-400/40 hover:shadow-[0_0_15px_rgba(6,182,212,0.25)] transition-all duration-300">
          <img src="/assets/icons/youtube.svg" alt="YouTube" class="w-4 h-4 md:w-5 md:h-5 opacity-90 hover:opacity-100" />
        </a>
      </div>
    </footer>
  </div>
</Layout>

<style>
  /* Viewport locking */
  :global(body) {
    overflow: hidden !important;
    height: 100vh !important;
    margin: 0 !important;
    padding: 0 !important;
  }

  /* Exquisite smooth float animation */
  @keyframes float {
    0%, 100% {
      transform: translateY(0px) rotate(0deg) scale(1);
    }
    50% {
      transform: translateY(-12px) rotate(1.5deg) scale(1.01);
    }
  }

  .animate-float {
    animation: float 7s ease-in-out infinite;
  }

  /* Slow rotate for planet */
  @keyframes spin-slow {
    from {
      transform: rotate(0deg);
    }
    to {
      transform: rotate(360deg);
    }
  }

  .animate-spin-slow {
    animation: spin-slow 180s linear infinite;
  }

  /* Subtle pulsing glows */
  @keyframes pulse-slow {
    0%, 100% { opacity: 0.8; transform: scale(1); }
    50% { opacity: 0.9; transform: scale(1.03); }
  }
  @keyframes pulse-slow-reverse {
    0%, 100% { opacity: 0.9; transform: scale(1.02); }
    50% { opacity: 0.8; transform: scale(1); }
  }

  .animate-pulse-slow {
    animation: pulse-slow 8s ease-in-out infinite;
  }
  .animate-pulse-slow-reverse {
    animation: pulse-slow-reverse 8s ease-in-out infinite;
  }

  /* Slow elegant pulse for title background */
  @keyframes pulse-glow {
    0%, 100% {
      filter: drop-shadow(0 0 10px rgba(6, 182, 212, 0.1));
    }
    50% {
      filter: drop-shadow(0 0 25px rgba(99, 102, 241, 0.25));
    }
  }

  .animate-pulse-slow {
    animation: pulse-glow 5s ease-in-out infinite;
  }

  /* Tech scanner line animation */
  @keyframes scan {
    0% { transform: translateY(-10px); opacity: 0; }
    15% { opacity: 0.5; }
    85% { opacity: 0.5; }
    100% { transform: translateY(320px); opacity: 0; }
  }
  .animate-scan {
    animation: scan 6s cubic-bezier(0.4, 0, 0.2, 1) infinite;
  }
</style>
