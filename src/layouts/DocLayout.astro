---
import Layout from './Layout.astro';
import Starfield from '../components/Starfield.astro';
import { getCollection } from 'astro:content';

interface Props {
  title: string;
  activeSlug: string;
}

const { title, activeSlug } = Astro.props;

// Fetch and sort all documents in the collection
const allDocs = await getCollection('docs');
const sortedDocs = allDocs.sort((a, b) => (a.data.order || 0) - (b.data.order || 0));
---

<Layout title={`${title} | Cosmicrafts Docs`}>
  <div class="fixed inset-0 h-screen w-screen overflow-hidden flex flex-col justify-between p-4 md:p-8 select-none z-10">
    <!-- Starfield Background -->
    <Starfield />

    <!-- Ambient blur glows in background -->
    <div class="absolute top-1/4 left-1/4 w-[400px] h-[400px] bg-cyan-500/5 rounded-full blur-[100px] pointer-events-none z-0"></div>
    <div class="absolute bottom-1/4 right-1/4 w-[400px] h-[400px] bg-indigo-500/5 rounded-full blur-[100px] pointer-events-none z-0"></div>

    <!-- Header -->
    <header class="w-full max-w-7xl mx-auto flex justify-between items-center z-10 pb-4 border-b border-white/5">
      <a href="/" class="flex items-center space-x-2">
        <img src="/logo.svg" alt="Cosmicrafts Logo" class="h-6 md:h-8 opacity-95" />
      </a>
      <a href="/" class="text-xs text-slate-400 hover:text-cyan-400 font-mono tracking-widest uppercase transition-all duration-300">
        ← Home
      </a>
    </header>

    <!-- Main Docs Area -->
    <main class="w-full max-w-7xl mx-auto flex-1 flex flex-col md:flex-row gap-6 md:gap-10 my-4 overflow-hidden z-10">
      <!-- Left: Sidebar Navigation -->
      <aside class="w-full md:w-64 flex flex-row md:flex-col overflow-x-auto md:overflow-x-visible md:overflow-y-auto shrink-0 gap-2 border-b md:border-b-0 md:border-r border-white/5 pb-4 md:pb-0 md:pr-6 scrollbar-none select-none">
        {sortedDocs.map((doc) => {
          const isActive = doc.slug === activeSlug;
          return (
            <a
              href={`/docs/${doc.slug}`}
              class={`px-4 py-2.5 rounded-lg text-xs md:text-sm font-mono tracking-wider uppercase border transition-all duration-300 whitespace-nowrap text-center md:text-left ${
                isActive
                  ? 'bg-cyan-500/10 border-cyan-400/35 text-cyan-400 shadow-[0_0_15px_rgba(34,211,238,0.1)]'
                  : 'bg-white/5 border-white/5 text-slate-400 hover:bg-white/10 hover:border-white/10 hover:text-white'
              }`}
            >
              {doc.data.title}
            </a>
          );
        })}
      </aside>

      <!-- Right: Markdown Content (Scrollable) -->
      <article class="flex-1 overflow-y-auto pr-2 md:pr-4 select-text max-h-[70vh] md:max-h-full scrollbar-thin">
        <div class="prose prose-invert prose-cyan max-w-none prose-p:text-slate-300 prose-headings:text-white prose-strong:text-white prose-li:text-slate-300 prose-img:rounded-xl">
          <slot />
        </div>
      </article>
    </main>

    <!-- Footer -->
    <footer class="w-full max-w-7xl mx-auto pt-4 border-t border-white/5 flex flex-col md:flex-row justify-between items-center z-10 gap-2">
      <p class="text-[10px] text-slate-600 font-mono">
        &copy; 2026 COSMICRAFTS. WHITE PAPER.
      </p>
      <p class="text-[10px] text-slate-500 font-mono tracking-wider uppercase">
        Ethereum Consensus MVP
      </p>
    </footer>
  </div>
</Layout>

<style is:global>
  /* Beautiful custom scrollbar for markdown text */
  .scrollbar-thin::-webkit-scrollbar {
    width: 4px;
    height: 4px;
  }
  .scrollbar-thin::-webkit-scrollbar-track {
    background: transparent;
  }
  .scrollbar-thin::-webkit-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.1);
    border-radius: 9999px;
  }
  .scrollbar-thin::-webkit-scrollbar-thumb:hover {
    background: rgba(15, 185, 253, 0.3);
  }

  /* Basic Markdown prose styles to ensure beautiful, rich output */
  .prose h1, .prose h2, .prose h3, .prose h4 {
    font-weight: 800;
    letter-spacing: -0.025em;
    text-transform: uppercase;
    margin-top: 1.5em;
    margin-bottom: 0.5em;
    color: #fff;
  }
  .prose h1 { font-size: 1.75rem; border-bottom: 1px solid rgba(255,255,255,0.08); padding-bottom: 0.5rem; }
  .prose h2 { font-size: 1.35rem; color: #22d3ee; }
  .prose h3 { font-size: 1.1rem; }
  .prose p { margin-bottom: 1rem; line-height: 1.625; font-size: 0.925rem; color: #cbd5e1; font-weight: 300; }
  .prose ul, .prose ol { margin-left: 1.5rem; margin-bottom: 1.25rem; list-style-type: square; font-size: 0.925rem; color: #cbd5e1; font-weight: 300; }
  .prose li { margin-bottom: 0.5rem; }
  .prose strong { font-weight: 700; color: #22d3ee; }
  .prose table { width: 100%; margin-top: 1.5rem; margin-bottom: 1.5rem; border-collapse: collapse; font-size: 0.85rem; font-family: monospace; }
  .prose th { border-bottom: 2px solid rgba(255,255,255,0.1); padding: 0.75rem; text-align: left; font-weight: 700; color: #22d3ee; }
  .prose td { border-bottom: 1px solid rgba(255,255,255,0.05); padding: 0.75rem; color: #94a3b8; }
  .prose blockquote { border-left: 4px solid #22d3ee; padding-left: 1rem; italic: true; margin-bottom: 1.25rem; color: #94a3b8; }
</style>
