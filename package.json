{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "setup": "npm i && dfx canister create backend && dfx generate backend && dfx deploy",
    "start": "vite --port 3000",
    "preview": "vite preview",
    "build": "tsc && vite build",
    "format": "prettier --write \"src/**/*.{json,js,jsx,ts,tsx,css,scss,vue}\"",
    "lint": "eslint \"src/**/*.{js,jsx,ts,tsx,vue}\"",
    "lint:fix": "eslint \"src/**/*.{js,jsx,ts,tsx,vue}\" --fix",
    "lint:check": "eslint \"src/**/*.{js,jsx,ts,tsx,vue}\" --max-warnings 0",
    "clean": "npm run lint:fix && npm run format",
    "lighthouse": "node scripts/lighthouse-audit.js",
    "lighthouse:mobile": "lighthouse http://localhost:3000 --output=html --output-path=./lighthouse-reports/mobile-report.html --chrome-flags='--headless' --preset=perf",
    "lighthouse:desktop": "lighthouse http://localhost:3000 --output=html --output-path=./lighthouse-reports/desktop-report.html --chrome-flags='--headless' --preset=perf --view",
    "audit": "npm run build && npm run lighthouse",
    "audit:ci": "npm run build && npm run lighthouse:mobile"
  },
  "devDependencies": {
    "@eslint/js": "^9.37.0",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/tsconfig": "^0.8.1",
    "autoprefixer": "^10.4.21",
    "chrome-launcher": "^1.2.1",
    "eslint": "^9.37.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-unused-imports": "^4.2.0",
    "eslint-plugin-vue": "^10.5.0",
    "glob": "^11.0.3",
    "globals": "^16.4.0",
    "lighthouse": "^13.0.0",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "sass-embedded": "^1.93.2",
    "tailwindcss": "^4.1.14",
    "terser": "^5.44.0",
    "typescript": "^5.9.3",
    "vite": "^7.1.10"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.1.0",
    "@heroicons/vue": "^2.2.0",
    "@microsoft/clarity": "^1.0.0",
    "@vueuse/core": "^13.9.0",
    "brotli-wasm": "^3.0.1",
    "chart.js": "^4.5.1",
    "d3": "^7.9.0",
    "date-fns": "^4.1.0",
    "gsap": "^3.13.0",
    "highlight.js": "^11.11.1",
    "lodash-es": "^4.17.21",
    "lottie-web": "^5.13.0",
    "markdown-it": "^14.1.0",
    "markdown-it-anchor": "^9.2.0",
    "markdown-it-container": "^4.0.0",
    "markdown-it-emoji": "^3.0.0",
    "markdown-it-highlightjs": "^4.2.0",
    "markdown-it-task-lists": "^2.1.1",
    "markdown-it-toc-done-right": "^4.2.0",
    "phaser": "^3.90.0",
    "pinia": "^3.0.3",
    "qrcode": "^1.5.4",
    "unity-webgl": "^4.4.3",
    "uuid": "^13.0.0",
    "vue": "^3.5.22",
    "vue-i18n": "^11.1.12",
    "vue-router": "^4.6.0"
  }
}
